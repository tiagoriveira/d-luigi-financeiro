// ═══ UTILS ════════════════════════════════════════════════
const fmt = v => 'R$ ' + Math.abs(v).toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2});
const fmtN = v => v.toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2});
const fmtSigned = v => (v>=0?'+':'')+fmtN(v);
const getIngr = id => S.ingredientes.find(i=>i.id===id);
function calcCustoDirecto(prod){
  return prod.ingrs.reduce((s,r)=>{const i=getIngr(r.ingrId);return s+(i?i.preco*r.qtd:0);},0);
}
function calcCustoPrep(prep){
  return prep.ingrs.reduce((s,r)=>{
    if(r.nome) return s+(r.preco||0)*(r.qtd2||0);
    const i=getIngr(r.ingrId);return s+(i?i.preco*r.qtd:0);
  },0);
}
function getMarkup(){
  const el=document.getElementById('markup-global-val');
  return el?parseFloat(el.dataset.val)/100:S.markup/100;
}
function calcPrecoSugerido(prod){
  const mk=getMarkup();
  return mk>0?calcCustoDirecto(prod)/mk:0;
}
function calcCustoTotal(prod){
  const cd=calcCustoDirecto(prod);
  const proj=S.cfg.projecao||90000;
  const desp=S.despesas.reduce((s,d)=>s+d.valor,0);
  const sal=S.salarios.reduce((s,d)=>s+d.salario*1.18,0);
  const pl=S.prolabore.reduce((s,d)=>s+d.valor,0);
  const totalFixos=desp+sal+pl;
  const rateio=proj>0?(totalFixos/proj)*prod.precoAtual:0;
  return cd+rateio;
}
function getMargemBenchmark(margem){
  if(margem>=20) return {cls:'badge-green',txt:'✓ Excelente'};
  if(margem>=12) return {cls:'badge-green',txt:'✓ Saudável'};
  if(margem>=5)  return {cls:'badge-yellow',txt:'⚠ Atenção'};
  return {cls:'badge-red',txt:'✗ Crítico'};
}
function toast(msg,tipo='ok',delay=2600){
  const t=document.getElementById('toast');
  t.textContent=msg;t.className='show'+(tipo==='error'?' error':'');
  setTimeout(()=>t.classList.remove('show','error'),delay);
}
function handleAdd(){
  const s=document.querySelector('.section.active');
  if(!s)return;
  const id=s.id.replace('sec-','');
  const map={ingredientes:'ingr-nome',caixa:'cx-valor',despesas:'pl-valor',vendadireta:null};
  if(id in map && map[id]) document.getElementById(map[id]).focus();
  else if(id==='vendadireta') addVendaDireta();
  else toast('Use o formulário na seção para adicionar');
}
function exportCSV(){
  const rows=[['Data','Tipo','Descrição','Conta','Valor']];
  S.lancamentos.forEach(l=>rows.push([l.data,l.tipo,l.desc,l.conta,l.valor]));
  const csv=rows.map(r=>r.join(',')).join('\n');
  const a=document.createElement('a');
  a.href='data:text/csv;charset=utf-8,'+encodeURIComponent(csv);
  a.download='fluxo_caixa.csv';a.click();
  toast('CSV exportado ✓');
}

// ═══ NAVIGATION ══════════════════════════════════════════
const pageMeta={
  dashboard:['Dashboard','Maio 2025 · Visão Geral'],
  ingredientes:['Ingredientes','Base de preços para cálculo das fichas'],
  preparacoes:['Preparações','Massas, molhos e subprodutos da cozinha'],
  produtos:['Fichas de Custo','Preço calculado automaticamente por produto'],
  vendadireta:['Venda Direta','Bebidas e itens de revenda'],
  despesas:['Despesas, Salários & Configurações','Estrutura de custos fixos do negócio'],
  caixa:['Fluxo de Caixa','Movimentações diárias do mês'],
  fechamento:['Fechamento do Mês','Input mensal guiado — notas, custos e relatório para o contador'],
  metaads:['Meta Ads','Calculadora de ponto de equilíbrio e desempenho de campanhas'],
  categorias:['Categorias','Personalize tipos de custo, contas bancárias e categorias de despesa'],
  integracao:['Integração Cardápio Web','Sincronização automática de produtos, preços e pedidos'],
};
function nav(id,el){
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('sec-'+id).classList.add('active');
  const[t,m]=pageMeta[id];
  document.getElementById('page-title').textContent=t;
  document.getElementById('page-meta').textContent=m;
  renderSection(id);
}
function renderSection(id){
  ({dashboard:renderDashboard,ingredientes:renderIngredientes,
    preparacoes:renderPreparacoes,produtos:renderProdutos,
    vendadireta:renderVendaDireta,despesas:renderDespesas,
    caixa:renderCaixa,integracao:renderIntegracao,
    metaads:renderMetaAds,fechamento:renderFechamento,
    categorias:renderCategorias})[id]?.();
}

// ═══ ONBOARDING ══════════════════════════════════════════
let obStep=1;
const obHints=[
  '<strong>1. Configure o negócio:</strong> Vá em "Despesas & Salários" → Role até "Configurações do Negócio". Coloque seu faturamento esperado, regime de imposto e quanto de lucro quer ter.',
  '<strong>2. Cadastre ingredientes:</strong> Vá em "Ingredientes" e adicione cada item que você compra com o preço atual por kg ou unidade. Mantenha sempre atualizado.',
  '<strong>3. Monte as fichas:</strong> Vá em "Fichas de Custo". O sistema já calculou o preço sugerido de cada produto. Compare com o que você pratica e ajuste se necessário.',
];
function obNext(){
  if(obStep<3){
    document.getElementById('ob-step-'+obStep).classList.replace('active','done');
    obStep++;
    document.getElementById('ob-step-'+obStep).classList.add('active');
    document.getElementById('ob-hint').innerHTML=obHints[obStep-1];
    if(obStep===3) document.querySelector('#onboarding .btn-primary').textContent='Entendido!';
  } else { closeOb(); }
}
function closeOb(){document.getElementById('onboarding').classList.add('hidden');}

// ═══ DASHBOARD ═══════════════════════════════════════════
let cFluxo=null,cCustos=null;
function renderDashboard(){
  const lc=S.lancamentos;
  const entradas=lc.filter(l=>l.valor>0).reduce((s,l)=>s+l.valor,0);
  const cmv=lc.filter(l=>l.tipo==='MP').reduce((s,l)=>s+Math.abs(l.valor),0);
  const desp=S.despesas.reduce((s,d)=>s+d.valor,0);
  const sal=S.salarios.reduce((s,d)=>s+d.salario*1.18,0);
  const pl=S.prolabore.reduce((s,d)=>s+d.valor,0);
  const totalDesp=desp+sal+pl;
  const lucro=entradas-cmv-totalDesp;

  document.getElementById('kpi-fat').textContent=fmt(entradas);
  document.getElementById('kpi-fat-d').textContent='Total de entradas no período';
  document.getElementById('kpi-cmv').textContent=fmt(cmv);
  const cmvPct=entradas>0?(cmv/entradas*100):0;
  document.getElementById('kpi-cmv-pct').textContent=cmvPct.toFixed(1)+'% do faturamento';
  document.getElementById('kpi-cmv-pct').className='kpi-delta '+(cmvPct<35?'pos':cmvPct<45?'warn':'neg');
  document.getElementById('kpi-cmv-bar').style.width=Math.min(cmvPct,100)+'%';
  document.getElementById('kpi-desp').textContent=fmt(totalDesp);
  const despPct=entradas>0?(totalDesp/entradas*100):0;
  document.getElementById('kpi-desp-pct').textContent=despPct.toFixed(1)+'% do faturamento';
  document.getElementById('kpi-desp-pct').className='kpi-delta '+(despPct<45?'pos':'neg');
  document.getElementById('kpi-desp-bar').style.width=Math.min(despPct,100)+'%';
  document.getElementById('kpi-lucro').textContent=fmt(Math.abs(lucro));
  const lucroPct=entradas>0?(lucro/entradas*100):0;
  document.getElementById('kpi-lucro-pct').textContent=lucroPct.toFixed(1)+'% de margem';
  document.getElementById('kpi-lucro-pct').className='kpi-delta '+(lucro>=0?'pos':'neg');
  document.getElementById('kpi-lucro-bar').style.width=Math.max(0,Math.min(Math.abs(lucroPct),100))+'%';

  // Alerts
  const alerts=[];
  if(cmvPct>40) alerts.push({cls:'alert-warn',icon:'⚠️',t:'Custo de insumos alto',m:`Seus ingredientes estão consumindo ${cmvPct.toFixed(1)}% do faturamento. O ideal para pizzarias é abaixo de 35%. Revise as fichas de custo ou renegocie com fornecedores.`});
  if(lucro<0) alerts.push({cls:'alert-red',icon:'🚨',t:'Resultado negativo no período',m:'As entradas registradas não cobrem os custos. Verifique se todos os lançamentos foram feitos corretamente.'});
  else if(lucroPct<5) alerts.push({cls:'alert-warn',icon:'⚠️',t:'Margem muito baixa',m:`Margem de ${lucroPct.toFixed(1)}%. Para ter reserva e reinvestir, o recomendado é acima de 8%.`});
  const aEl=document.getElementById('dashboard-alerts');
  aEl.innerHTML=alerts.map(a=>`<div class="alert ${a.cls}"><span class="alert-icon">${a.icon}</span><div><div class="alert-title">${a.t}</div>${a.m}</div></div>`).join('');

  // Tabela análise
  const tbody=document.getElementById('tb-analise');
  tbody.innerHTML=S.produtos.map(p=>{
    const cd=calcCustoDirecto(p);
    const ct=calcCustoTotal(p);
    const margem=p.precoAtual>0?((p.precoAtual-ct)/p.precoAtual*100):0;
    const bm=getMargemBenchmark(margem);
    return `<tr>
      <td style="font-weight:500">${p.nome}</td>
      <td><span class="badge badge-neutral">${p.tamanho}</span></td>
      <td class="td-mono">${fmt(cd)}</td>
      <td class="td-mono">${fmt(ct)}</td>
      <td class="td-mono" style="font-weight:600">${fmt(p.precoAtual)}</td>
      <td class="td-mono" style="font-weight:700;color:${margem>=12?'var(--green)':margem>=5?'var(--yellow)':'var(--red)'}">${margem.toFixed(1)}%</td>
      <td><span class="badge ${bm.cls}">${bm.txt}</span></td>
    </tr>`;
  }).join('');

  renderChartFluxo(lc);
  renderChartCustos(cmv,totalDesp,entradas);
}
function renderChartFluxo(lc){
  const dias=[...new Set(lc.map(l=>l.data))].sort();
  const rec=dias.map(d=>lc.filter(l=>l.data===d&&l.valor>0).reduce((s,l)=>s+l.valor,0));
  const sai=dias.map(d=>lc.filter(l=>l.data===d&&l.valor<0).reduce((s,l)=>s+Math.abs(l.valor),0));
  const labels=dias.map(d=>d.split('-')[2]+'/'+d.split('-')[1]);
  const ctx=document.getElementById('chartFluxo').getContext('2d');
  if(cFluxo)cFluxo.destroy();
  cFluxo=new Chart(ctx,{type:'bar',data:{labels,datasets:[
    {label:'Entradas',data:rec,backgroundColor:'rgba(44,110,73,.18)',borderColor:'#2C6E49',borderWidth:1.5,borderRadius:4},
    {label:'Saídas',data:sai,backgroundColor:'rgba(192,57,43,.13)',borderColor:'#C0392B',borderWidth:1.5,borderRadius:4},
  ]},options:{responsive:true,plugins:{legend:{labels:{font:{family:'DM Sans',size:11},boxWidth:10}}},
    scales:{x:{grid:{display:false},ticks:{font:{family:'DM Sans',size:10}}},
      y:{grid:{color:'rgba(0,0,0,0.04)'},ticks:{font:{family:'DM Sans',size:10},callback:v=>'R$'+(v/1000).toFixed(1)+'k'}}}}});
}
function renderChartCustos(cmv,desp,fat){
  const ctx=document.getElementById('chartCustos').getContext('2d');
  if(cCustos)cCustos.destroy();
  const lucro=Math.max(0,fat-cmv-desp);
  cCustos=new Chart(ctx,{type:'doughnut',data:{
    labels:['Custo de Ingredientes','Custos Fixos + Equipe','Lucro'],
    datasets:[{data:[cmv,desp,lucro],backgroundColor:['#BF6A2E','#C0392B','#2C6E49'],borderWidth:0,hoverOffset:4}]
  },options:{responsive:true,cutout:'65%',
    plugins:{legend:{position:'bottom',labels:{font:{family:'DM Sans',size:11},boxWidth:10,padding:10}},
      tooltip:{callbacks:{label:ctx=>`R$ ${ctx.parsed.toLocaleString('pt-BR',{minimumFractionDigits:2})}`}}}}});
}

// ═══ INGREDIENTES ════════════════════════════════════════
function renderIngredientes(){
  const q=S.filtroIngr.toLowerCase();
  const lista=S.ingredientes.filter(i=>i.nome.toLowerCase().includes(q));
  const tbody=document.getElementById('tb-ingredientes');
  tbody.innerHTML=lista.length===0
    ?'<tr><td colspan="6"><div class="empty"><div class="empty-icon">🌿</div><div class="empty-title">Nenhum ingrediente encontrado</div><div class="empty-sub">Tente outro termo ou adicione um novo ingrediente</div></div></td></tr>'
    :lista.map(i=>{
      const diff=i.precoAnt?((i.preco-i.precoAnt)/i.precoAnt*100):0;
      const histHtml=i.precoAnt?`<span class="hist-chip ${diff>0?'up':diff<0?'down':''}">${diff>0?'↑':'↓'} ${Math.abs(diff).toFixed(1)}%</span>`:'—';
      const antHtml=i.precoAnt?`<span class="td-mono muted">${fmt(i.precoAnt)}</span>`:'<span class="muted">—</span>';
      return `<tr>
        <td style="font-weight:500">${i.nome}</td>
        <td><span class="badge badge-neutral">${i.unid}</span></td>
        <td class="text-right td-mono">${fmt(i.preco)}</td>
        <td class="text-right">${antHtml}</td>
        <td class="text-right">${histHtml}</td>
        <td class="text-right" style="display:flex;gap:6px;justify-content:flex-end">
          <button class="btn btn-ghost btn-xs" onclick="editIngr(${i.id})">Atualizar preço</button>
          <button class="btn btn-danger btn-xs" onclick="delIngr(${i.id})">×</button>
        </td>
      </tr>`;
    }).join('');

  // Indiretos
  const proj=S.cfg.projecao||90000;
  const tbody2=document.getElementById('tb-indir');
  let total=0,totalUn=0;
  tbody2.innerHTML=S.indiretos.map(i=>{
    const sub=(i.preco||0)*(i.qtdeMes||0);
    const porUn=proj>0?sub/proj:0;
    total+=sub;totalUn+=porUn;
    return `<tr>
      <td style="font-weight:500">${i.nome}</td>
      <td><span class="badge badge-neutral">${i.unid}</span></td>
      <td class="text-right td-mono">${fmt(i.preco)}</td>
      <td class="text-right"><input type="number" value="${i.qtdeMes||''}" placeholder="—"
        style="width:80px;text-align:right;padding:4px 8px;font-size:12px"
        oninput="updateIndir(${i.id},this.value)"></td>
      <td class="text-right td-mono">${i.qtdeMes?fmt(sub):'<span class="muted">—</span>'}</td>
      <td class="text-right td-mono muted" style="font-size:11.5px">${i.qtdeMes?fmt(porUn)+'/venda':'—'}</td>
    </tr>`;
  }).join('');
  document.getElementById('total-indir').textContent=total>0?fmt(total):'R$ —';
  document.getElementById('total-indir-un').textContent=totalUn>0?fmt(totalUn)+'/venda':'—';
}
function filtrarIngredientes(){S.filtroIngr=document.getElementById('busca-ingr').value;renderIngredientes();}
function addIngrediente(){
  const nome=document.getElementById('ingr-nome').value.trim();
  const unid=document.getElementById('ingr-unid').value;
  const preco=parseFloat(document.getElementById('ingr-preco').value);
  if(!nome){document.getElementById('ingr-nome').classList.add('error');toast('Digite o nome do ingrediente','error');return;}
  if(isNaN(preco)||preco<0){document.getElementById('ingr-preco').classList.add('error');toast('Digite um preço válido','error');return;}
  document.getElementById('ingr-nome').classList.remove('error');
  document.getElementById('ingr-preco').classList.remove('error');
  S.ingredientes.push({id:IDs.ingr++,nome,unid,preco,precoAnt:null});
  document.getElementById('ingr-nome').value='';document.getElementById('ingr-preco').value='';
  renderIngredientes();toast('Ingrediente adicionado ✓');
}
function editIngr(id){
  const i=S.ingredientes.find(x=>x.id===id);if(!i)return;
  const nv=prompt(`Novo preço para "${i.nome}" por ${i.unid} (R$):\n\nPreço atual: R$ ${fmtN(i.preco)}`,i.preco);
  if(nv===null)return;
  const p=parseFloat(nv.replace(',','.'));
  if(!isNaN(p)&&p>=0){i.precoAnt=i.preco;i.preco=p;renderIngredientes();toast('Preço atualizado — histórico salvo ✓');}
  else toast('Valor inválido','error');
}
function delIngr(id){
  if(!confirm('Remover este ingrediente? Produtos que usam ele podem ter custo zerado.'))return;
  S.ingredientes=S.ingredientes.filter(i=>i.id!==id);renderIngredientes();toast('Ingrediente removido');
}
function updateIndir(id,val){
  const i=S.indiretos.find(x=>x.id===id);
  if(i){i.qtdeMes=parseFloat(val)||null;renderIngredientes();}
}
function addIndir(){
  const nome=prompt('Nome do item (ex: Caixa de pizza, Guardanapo):');if(!nome)return;
  const preco=parseFloat(prompt('Preço por unidade (R$):')?.replace(',','.'));
  if(isNaN(preco))return;
  S.indiretos.push({id:IDs.indir++,nome,unid:'unidade',preco,qtdeMes:null});
  renderIngredientes();toast('Item adicionado ✓');
}

// ═══ PREPARAÇÕES ═════════════════════════════════════════
function renderPreparacoes(){
  const grid=document.getElementById('grid-preps');
  grid.innerHTML=S.preparacoes.map(p=>{
    const custo=calcCustoPrep(p);
    const ingrsHtml=p.ingrs.map(r=>{
      const nome=r.nome||getIngr(r.ingrId)?.nome||'?';
      const qtd=r.qtd2||r.qtd;
      const pr=r.preco?r.preco:(getIngr(r.ingrId)?.preco||0);
      const c=pr*qtd;
      return `<div class="prep-ingr-row"><span>${nome}</span><span style="font-size:10.5px;color:var(--text-3)">${qtd} ${r.nome?'kg':getIngr(r.ingrId)?.unid||''}</span><span style="font-weight:500;font-variant-numeric:tabular-nums">${fmt(c)}</span></div>`;
    }).join('');
    return `<div class="prep-card">
      <div class="prep-header">
        <div>
          <div class="prep-name">${p.nome}</div>
          <div style="font-size:10.5px;color:#6B7FD7">Rendimento: ${p.rendimento}</div>
        </div>
        <span class="badge badge-blue">Preparação</span>
      </div>
      <div class="prep-body">${ingrsHtml}</div>
      <div class="prep-footer">
        <span style="font-size:11px;color:var(--text-3)">Custo desta preparação:</span>
        <span style="font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:500;color:var(--text)">${fmt(custo)}</span>
      </div>
    </div>`;
  }).join('');
}

// ═══ PRODUTOS ════════════════════════════════════════════
function filtrarProdutos(filtro,el){
  S.filtroProduto=filtro;
  document.querySelectorAll('#tabs-produtos .pill-tab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');renderProdutos();
}
function renderProdutos(){
  recalcMarkup();
  const mk=getMarkup();
  document.getElementById('markup-display').textContent=(mk*100).toFixed(1)+'%';
  const lista=S.filtroProduto==='todos'?S.produtos:S.produtos.filter(p=>p.filtro===S.filtroProduto);
  const grid=document.getElementById('grid-produtos');
  grid.innerHTML=lista.map(p=>{
    const ingrsHtml=p.ingrs.map(r=>{
      const i=getIngr(r.ingrId);if(!i)return'';
      const c=i.preco*r.qtd;
      return `<div class="ingr-row"><span class="ingr-name">${i.nome}</span><span class="ingr-qtd">${r.qtd} ${i.unid}</span><span class="ingr-custo">${fmt(c)}</span></div>`;
    }).join('');
    const cd=calcCustoDirecto(p);
    const ps=mk>0?cd/mk:0;
    const diff=p.precoAtual-ps;
    const margemAtual=p.precoAtual>0?((p.precoAtual-cd)/p.precoAtual*100):0;
    const bm=getMargemBenchmark(margemAtual);
    const aviso=ps>0&&Math.abs(diff/ps)>0.15?`<div class="alert ${diff<0?'alert-warn':'alert-info'}" style="margin-top:8px;padding:8px 10px">
      <span style="font-size:12px">${diff<0?'⚠️':'ℹ️'}</span>
      <span style="font-size:11px">${diff<0?'Preço abaixo do sugerido. Risco de prejuízo.':'Preço acima do sugerido. Boa margem.'}</span>
    </div>`:'';
    return `<div class="produto-card">
      <div class="produto-card-header">
        <div class="produto-name">${p.nome}</div>
        <div class="produto-tamanho">${p.tamanho}</div>
      </div>
      <div class="produto-body">
        ${ingrsHtml}
        <div style="padding:7px 0 0;display:flex;justify-content:space-between;font-size:12px;font-weight:600;margin-top:4px;border-top:1px dashed var(--border)">
          <span style="color:var(--text-2)">Custo dos ingredientes:</span><span>${fmt(cd)}</span>
        </div>
        ${aviso}
      </div>
      <div class="produto-footer">
        <div class="pf-grid">
          <div><div class="pf-label">Preço Sugerido</div><div class="pf-value accent">${fmt(ps)}</div></div>
          <div><div class="pf-label">Preço Praticado</div>
            <input type="number" value="${p.precoAtual}" step="1" min="0"
              style="width:100%;padding:3px 6px;font-size:14px;font-weight:600;margin-top:3px;border-radius:6px"
              oninput="updatePreco(${p.id},this.value)">
          </div>
        </div>
        <div style="display:flex;justify-content:space-between;align-items:center;padding-top:8px;border-top:1px solid var(--border)">
          <span class="badge ${bm.cls}">${bm.txt}</span>
          <span style="font-size:11px;color:var(--text-3)">Margem: <strong style="color:${margemAtual>=12?'var(--green)':margemAtual>=5?'var(--yellow)':'var(--red)'}">${margemAtual.toFixed(1)}%</strong></span>
        </div>
      </div>
    </div>`;
  }).join('');
}
function updatePreco(id,val){
  const p=S.produtos.find(x=>x.id===id);
  if(p){p.precoAtual=parseFloat(val)||0;renderProdutos();}
}

// ═══ VENDA DIRETA ════════════════════════════════════════
function renderVendaDireta(){
  const mkBeb=parseFloat(document.getElementById('markup-bebidas').value||40)/100;
  const tbody=document.getElementById('tb-vd');
  let totalLucro=0;
  tbody.innerHTML=S.vendaDireta.map(v=>{
    const ps=mkBeb>0?v.custo/mkBeb:0;
    const lucroUn=v.precoAtual-v.custo;
    const lucroMes=lucroUn*(v.previsaoMes||0);
    totalLucro+=lucroMes;
    const ok=lucroUn>0;
    return `<tr>
      <td style="font-weight:500">${v.nome}</td>
      <td><span class="badge badge-blue">${v.categoria}</span></td>
      <td class="text-right td-mono">${fmt(v.custo)}</td>
      <td class="text-right td-mono" style="color:var(--accent)">${fmt(ps)}</td>
      <td class="text-right"><input type="number" value="${v.precoAtual}" step="0.5" min="0"
        style="width:70px;text-align:right;padding:4px 6px;font-size:12px;font-weight:600"
        oninput="updateVD(${v.id},'preco',this.value)"></td>
      <td class="text-right td-mono" style="font-weight:600;color:${ok?'var(--green)':'var(--red)'}">${fmtSigned(lucroUn)}</td>
      <td class="text-right"><input type="number" value="${v.previsaoMes||''}" placeholder="—"
        style="width:70px;text-align:right;padding:4px 6px;font-size:12px"
        oninput="updateVD(${v.id},'prev',this.value)"></td>
      <td class="text-right td-mono" style="font-weight:600;color:${lucroMes>=0?'var(--green)':'var(--red)'}">${v.previsaoMes?fmt(lucroMes):'—'}</td>
      <td><button class="btn btn-danger btn-xs" onclick="delVD(${v.id})">×</button></td>
    </tr>`;
  }).join('');
  document.getElementById('total-vd-lucro').textContent=totalLucro>0?fmt(totalLucro):'—';
}
function updateVD(id,campo,val){
  const v=S.vendaDireta.find(x=>x.id===id);
  if(!v)return;
  if(campo==='preco')v.precoAtual=parseFloat(val)||0;
  else v.previsaoMes=parseInt(val)||0;
  renderVendaDireta();
}
function delVD(id){S.vendaDireta=S.vendaDireta.filter(v=>v.id!==id);renderVendaDireta();toast('Produto removido');}
function addVendaDireta(){
  const nome=prompt('Nome do produto:');if(!nome)return;
  const cat=prompt('Categoria (Refrigerante/Cerveja/Água/Vinho/Outro):','Refrigerante');if(!cat)return;
  const custo=parseFloat(prompt('Custo de compra (R$):')?.replace(',','.'));
  if(isNaN(custo))return;
  const preco=parseFloat(prompt('Preço de venda praticado (R$):')?.replace(',','.'));
  if(isNaN(preco))return;
  S.vendaDireta.push({id:IDs.vd++,nome,categoria:cat,custo,precoAtual:preco,previsaoMes:0});
  renderVendaDireta();toast('Produto adicionado ✓');
}

// ═══ DESPESAS ════════════════════════════════════════════
function recalcMarkup(){
  const imp=parseFloat(document.getElementById('cfg-regime')?.value||0.06);
  const luc=parseFloat(document.getElementById('cfg-lucro')?.value||10)/100;
  const mk=1-imp-luc;
  S.markup=mk*100;
  const el=document.getElementById('markup-global-val');
  if(!el){
    const d=document.createElement('span');
    d.id='markup-global-val';d.dataset.val=mk*100;d.style.display='none';
    document.body.appendChild(d);
  } else {el.dataset.val=mk*100;}
  const mkEl=document.getElementById('markup-calc');
  if(mkEl)mkEl.textContent=(mk*100).toFixed(2)+'%';
  return mk;
}
function recalcTudo(){
  S.cfg.projecao=parseFloat(document.getElementById('cfg-projecao')?.value||90000);
  S.cfg.imposto=parseFloat(document.getElementById('cfg-regime')?.value||0.06);
  S.cfg.lucro=parseFloat(document.getElementById('cfg-lucro')?.value||10)/100;
  recalcMarkup();
  renderDespesas();
}
function renderDespesas(){
  recalcMarkup();
  const proj=parseFloat(document.getElementById('cfg-projecao')?.value||90000);
  const imp=parseFloat(document.getElementById('cfg-regime')?.value||0.06);
  const luc=parseFloat(document.getElementById('cfg-lucro')?.value||10)/100;
  const mk=1-imp-luc;
  document.getElementById('markup-calc').textContent=(mk*100).toFixed(2)+'%';

  const tbody=document.getElementById('tb-desp');
  let totalVal=0,totalRat=0;
  tbody.innerHTML=S.despesas.map(d=>{
    const rat=proj>0?d.valor/proj:0;totalVal+=d.valor;totalRat+=rat;
    return `<tr>
      <td>${d.desc}</td>
      <td class="text-right td-mono">${fmt(d.valor)}</td>
      <td class="text-right td-mono muted" style="font-size:11.5px">R$ ${fmtN(rat)} a cada R$1</td>
      <td><button class="btn btn-danger btn-xs" onclick="delDesp(${d.id})">×</button></td>
    </tr>`;
  }).join('');
  document.getElementById('total-desp-val').textContent=fmt(totalVal);
  document.getElementById('total-desp-rat').textContent='R$ '+fmtN(totalRat);

  // ProLabore
  const tbody3=document.getElementById('tb-prolabore');
  let tpl=0;
  tbody3.innerHTML=S.prolabore.map(p=>{
    tpl+=p.valor;
    return `<tr>
      <td style="font-weight:500">${p.nome}</td>
      <td class="text-right td-mono">${fmt(p.valor)}</td>
      <td><button class="btn btn-danger btn-xs" onclick="delProlabore(${p.id})">×</button></td>
    </tr>`;
  }).join('');
  document.getElementById('total-pl').textContent=fmt(tpl);

  // Salários
  const tbody2=document.getElementById('tb-salarios');
  let ts=0,tse=0;
  tbody2.innerHTML=S.salarios.map(s=>{
    const enc=s.salario*1.18;ts+=s.salario;tse+=enc;
    return `<tr>
      <td>${s.func}</td>
      <td class="text-right td-mono">${fmt(s.salario)}</td>
      <td class="text-right td-mono" style="font-weight:600;color:var(--accent)">${fmt(enc)}</td>
    </tr>`;
  }).join('');
  document.getElementById('total-sal').textContent=fmt(ts);
  document.getElementById('total-sal-enc').textContent=fmt(tse);

  // Breakdown
  const cmvEst=proj*0.30;
  const totalFixosCal=totalVal+tse+tpl;
  const lucroEst=proj-(cmvEst+totalFixosCal);
  const impEst=proj*imp;
  const breakdown=document.getElementById('cost-breakdown');
  const items=[
    {label:'Insumos (estimado 30%)',val:cmvEst/proj,color:'#BF6A2E'},
    {label:'Impostos',val:imp,color:'#9333EA'},
    {label:'Custos Fixos + Equipe',val:proj>0?totalFixosCal/proj:0,color:'#C0392B'},
    {label:'Lucro estimado',val:proj>0?Math.max(0,lucroEst)/proj:0,color:'#2C6E49'},
  ];
  breakdown.innerHTML=items.map(it=>`<div class="progress-wrap">
    <div class="progress-label"><span>${it.label}</span><span>${(it.val*100).toFixed(1)}%</span></div>
    <div class="progress-bar"><div class="progress-fill" style="width:${Math.min(it.val*100,100)}%;background:${it.color}"></div></div>
  </div>`).join('');
}
function addDespesa(){
  const desc=prompt('Descrição da despesa (ex: Aluguel, Energia):');if(!desc)return;
  const val=parseFloat(prompt('Valor mensal em R$:')?.replace(',','.'));
  if(isNaN(val)||val<0){toast('Valor inválido','error');return;}
  S.despesas.push({id:IDs.desp++,desc,valor:val});
  renderDespesas();toast('Despesa adicionada ✓');
}
function delDesp(id){S.despesas=S.despesas.filter(d=>d.id!==id);renderDespesas();toast('Despesa removida');}
function addProlabore(){
  const nome=document.getElementById('pl-nome').value.trim();
  const val=parseFloat(document.getElementById('pl-valor').value);
  if(!nome){toast('Digite o nome do sócio','error');return;}
  if(isNaN(val)||val<0){toast('Digite um valor válido','error');return;}
  S.prolabore.push({id:IDs.pl++,nome,valor:val});
  document.getElementById('pl-nome').value='';document.getElementById('pl-valor').value='';
  renderDespesas();toast('Pró-labore adicionado ✓');
}
function delProlabore(id){S.prolabore=S.prolabore.filter(p=>p.id!==id);renderDespesas();toast('Removido');}

// ═══ CAIXA ═══════════════════════════════════════════════
let cCaixa=null;
const CONTA_CORES={'Caixa':'#2C6E49','Pix':'#0284C7','Crédito':'#9333EA','Débito':'#E6A817','Sicoob PJ':'#BF6A2E','Santander':'#C0392B'};
const TIPO_LABEL={FL:'Venda',MP:'Ingrediente',FX:'Fixo',VA:'Variável',TX:'Taxa',OP:'Operacional'};
function renderCaixa(){
  const lc=S.filtroCaixa==='todos'?[...S.lancamentos]:S.lancamentos.filter(l=>l.tipo===S.filtroCaixa);
  lc.sort((a,b)=>a.data.localeCompare(b.data));
  let saldoAcum=0;
  const tbody=document.getElementById('tb-caixa');
  tbody.innerHTML=lc.map(l=>{
    saldoAcum+=l.valor;
    const pos=l.valor>=0;
    return `<tr>
      <td><div class="tipo-badge tipo-${l.tipo}">${l.tipo}</div></td>
      <td style="color:var(--text-3);font-size:11.5px;white-space:nowrap">${l.data.split('-').reverse().join('/')}</td>
      <td style="font-weight:500">${l.desc}</td>
      <td><span class="badge badge-neutral" style="font-size:10px">${l.conta}</span></td>
      <td class="text-right td-mono" style="color:${pos?'var(--green)':'var(--red)'};font-weight:600">${pos?'+':''}${fmtN(l.valor)}</td>
      <td class="text-right td-mono" style="color:${saldoAcum>=0?'var(--text)':'var(--red)'}">${fmtN(saldoAcum)}</td>
      <td><button class="btn btn-danger btn-xs" onclick="delLancamento(${l.id})">×</button></td>
    </tr>`;
  }).join('');

  const saldoTotal=S.lancamentos.reduce((s,l)=>s+l.valor,0);
  const saldoEl=document.getElementById('saldo-total');
  saldoEl.textContent=fmt(Math.abs(saldoTotal));
  saldoEl.className='saldo-value '+(saldoTotal>=0?'pos':'neg');

  const contas={};
  S.lancamentos.forEach(l=>{contas[l.conta]=(contas[l.conta]||0)+l.valor;});
  document.getElementById('resumo-contas').innerHTML=Object.entries(contas).map(([c,v])=>
    `<div class="resumo-conta">
      <span style="display:flex;align-items:center;gap:7px">
        <span class="conta-dot" style="background:${CONTA_CORES[c]||'#888'}"></span>
        <span>${c}</span>
      </span>
      <span style="font-weight:600;color:${v>=0?'var(--green)':'var(--red)'}">${fmt(v)}</span>
    </div>`).join('');

  const tipos={FL:0,MP:0,FX:0,VA:0,TX:0,OP:0};
  S.lancamentos.forEach(l=>{if(tipos[l.tipo]!==undefined)tipos[l.tipo]+=l.valor;});
  document.getElementById('resumo-tipos').innerHTML=Object.entries(tipos)
    .filter(([,v])=>v!==0)
    .map(([t,v])=>`<div style="display:flex;justify-content:space-between;padding:4px 0;font-size:12px;border-bottom:1px solid var(--border)">
      <span style="display:flex;align-items:center;gap:7px">
        <span class="tipo-badge tipo-${t}" style="width:22px;height:22px;font-size:8.5px">${t}</span>
        <span style="color:var(--text-2)">${TIPO_LABEL[t]}</span>
      </span>
      <span style="font-weight:600;color:${v>=0?'var(--green)':'var(--red)'}">${fmt(v)}</span>
    </div>`).join('');

  const ctx=document.getElementById('chartCaixa').getContext('2d');
  if(cCaixa)cCaixa.destroy();
  const allE=Object.entries(tipos).filter(([,v])=>v!==0);
  cCaixa=new Chart(ctx,{type:'bar',data:{
    labels:allE.map(([t])=>TIPO_LABEL[t]),
    datasets:[{data:allE.map(([,v])=>Math.abs(v)),
      backgroundColor:allE.map(([,v])=>v>=0?'rgba(44,110,73,.75)':'rgba(192,57,43,.65)'),
      borderRadius:3,borderWidth:0}]
  },options:{responsive:true,indexAxis:'y',
    plugins:{legend:{display:false}},
    scales:{x:{grid:{color:'rgba(0,0,0,0.04)'},ticks:{font:{family:'DM Sans',size:10},callback:v=>'R$'+v.toFixed(0)}},
      y:{grid:{display:false},ticks:{font:{family:'DM Sans',size:10}}}}}});
}
function addLancamento(){
  const data=document.getElementById('cx-data').value;
  const tipo=document.getElementById('cx-tipo').value;
  const desc=document.getElementById('cx-desc').value.trim();
  const val=parseFloat(document.getElementById('cx-valor').value);
  const conta=document.getElementById('cx-conta').value;
  if(!data){toast('Selecione a data','error');return;}
  if(!desc){document.getElementById('cx-desc').classList.add('error');toast('Descreva a movimentação','error');return;}
  if(isNaN(val)||val<=0){document.getElementById('cx-valor').classList.add('error');toast('Digite um valor maior que zero','error');return;}
  document.getElementById('cx-desc').classList.remove('error');
  document.getElementById('cx-valor').classList.remove('error');
  const valorFinal=tipo==='FL'?Math.abs(val):-Math.abs(val);
  S.lancamentos.push({id:IDs.cx++,data,tipo,desc,valor:valorFinal,conta});
  document.getElementById('cx-desc').value='';document.getElementById('cx-valor').value='';
  renderCaixa();toast('Lançamento registrado ✓');
}
function delLancamento(id){
  S.lancamentos=S.lancamentos.filter(l=>l.id!==id);renderCaixa();toast('Lançamento removido');
}
function filtrarCaixa(filtro,el){
  S.filtroCaixa=filtro;
  document.querySelectorAll('#sec-caixa .btn-ghost.btn-xs').forEach(b=>b.style.background='');
  if(el)el.style.background='var(--surface-3)';
  renderCaixa();
}

// ═══ INTEGRAÇÃO CARDÁPIO WEB ══════════════════════════════
const CW = {
  token: null,
  lojaId: null,
  connected: false,
  syncLog: [],
  catalogoImportado: [],
};

// Dados simulados — representam o que a API real retornaria
const CW_MOCK = {
  loja: {
    nome: "D'Luigi Pizzaria",
    cnpj: "12.345.678/0001-90",
    status: "aberto",
    formasPagamento: ["Dinheiro","Pix","Crédito","Débito"],
    horarios: "Seg-Dom 18h–23h",
  },
  catalogo: [
    {id:'cw-001',nome:'Pizza Americana Família',categoria:'Pizzas',preco:107,status:'ativo'},
    {id:'cw-002',nome:'Pizza Americana Grande',categoria:'Pizzas',preco:65,status:'ativo'},
    {id:'cw-003',nome:'Pizza Americana Broto',categoria:'Pizzas',preco:33,status:'ativo'},
    {id:'cw-004',nome:'Pizza À Moda da Casa Família',categoria:'Pizzas',preco:112,status:'ativo'},
    {id:'cw-005',nome:'Pizza À Moda da Casa Grande',categoria:'Pizzas',preco:70,status:'ativo'},
    {id:'cw-006',nome:'Pizza À Moda da Casa Broto',categoria:'Pizzas',preco:36,status:'ativo'},
    {id:'cw-007',nome:'Pizza Especial do Pizzaiolo Família',categoria:'Pizzas',preco:120,status:'ativo'},
    {id:'cw-008',nome:'Pizza Especial do Pizzaiolo Grande',categoria:'Pizzas',preco:75,status:'ativo'},
    {id:'cw-009',nome:'Coca-Cola 350ml',categoria:'Bebidas',preco:5,status:'ativo'},
    {id:'cw-010',nome:'Guaraná Antarctica 350ml',categoria:'Bebidas',preco:5,status:'ativo'},
    {id:'cw-011',nome:'Brahma Chopp 350ml',categoria:'Bebidas',preco:5,status:'ativo'},
    {id:'cw-012',nome:'Água Mineral 510ml',categoria:'Bebidas',preco:2.5,status:'ativo'},
    {id:'cw-013',nome:'Porção de Batata Frita',categoria:'Porções',preco:38,status:'ativo'},
    {id:'cw-014',nome:'Strogonoff de Frango',categoria:'Porções',preco:52,status:'ativo'},
    {id:'cw-015',nome:'Pizza Margherita Família',categoria:'Pizzas',preco:95,status:'inativo'},
  ],
  // Pedidos simulados para o período (agrupados por dia e forma pagamento)
  pedidos: (periodo) => {
    const [ano, mes] = periodo.split('-');
    const diasNoMes = new Date(ano, mes, 0).getDate();
    const result = [];
    let idBase = 5000;
    const formas = [
      {conta:'Caixa',label:'Dinheiro',peso:0.15},
      {conta:'Pix',label:'Pix',peso:0.35},
      {conta:'Crédito',label:'Cartão Crédito',peso:0.30},
      {conta:'Débito',label:'Cartão Débito',peso:0.20},
    ];
    for(let d=1;d<=diasNoMes;d++){
      // Simula mais movimento nos fins de semana
      const date = new Date(ano, mes-1, d);
      const dow = date.getDay(); // 0=dom, 6=sab
      const fimDeSemana = dow===0||dow===5||dow===6;
      const baseVenda = fimDeSemana ? 3200 : 1400;
      const variacao = 0.7 + Math.random()*0.6;
      const totalDia = baseVenda * variacao;
      const numPedidos = Math.round((fimDeSemana?28:12)*variacao);
      formas.forEach(f=>{
        const valor = totalDia * f.peso;
        result.push({
          id: idBase++,
          data: `${ano}-${mes.padStart(2,'0')}-${String(d).padStart(2,'0')}`,
          tipo: 'FL',
          desc: `[CW] Vendas ${f.label}`,
          valor: Math.round(valor*100)/100,
          conta: f.conta,
          numPedidos: Math.round(numPedidos*f.peso),
          fonte: 'cardapio_web',
        });
      });
    }
    return result;
  },
  // Volume de vendas por produto no período
  volumeProdutos: [
    {cwId:'cw-001',qtd:42,faturamento:4494},
    {cwId:'cw-002',qtd:89,faturamento:5785},
    {cwId:'cw-003',qtd:134,faturamento:4422},
    {cwId:'cw-004',qtd:38,faturamento:4256},
    {cwId:'cw-005',qtd:74,faturamento:5180},
    {cwId:'cw-006',qtd:98,faturamento:3528},
    {cwId:'cw-007',qtd:22,faturamento:2640},
    {cwId:'cw-008',qtd:45,faturamento:3375},
    {cwId:'cw-009',qtd:280,faturamento:1400},
    {cwId:'cw-010',qtd:210,faturamento:1050},
    {cwId:'cw-011',qtd:156,faturamento:780},
    {cwId:'cw-012',qtd:390,faturamento:975},
    {cwId:'cw-013',qtd:67,faturamento:2546},
    {cwId:'cw-014',qtd:34,faturamento:1768},
  ],
};

function integTab(id, el){
  document.querySelectorAll('.integ-tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.integ-panel').forEach(p=>p.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('ip-'+id).classList.add('active');
}

function renderIntegracao(){
  updateConnBadge();
  // Set current month as default period
  const now = new Date();
  const ped = document.getElementById('ped-periodo');
  if(ped && !ped.value){
    ped.value = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}`;
  }
}

function updateConnBadge(){
  const badge = document.getElementById('sidebar-badge');
  const connBadge = document.getElementById('conn-status-badge');
  if(!badge||!connBadge) return;
  if(CW.connected){
    badge.textContent='✓ On';badge.className='sidebar-conn-badge on';
    connBadge.innerHTML='<span class="conn-dot"></span> Conectado';
    connBadge.className='conn-status connected';
  } else {
    badge.textContent='✗ Off';badge.className='sidebar-conn-badge off';
    connBadge.innerHTML='<span class="conn-dot"></span> Não conectado';
    connBadge.className='conn-status disconnected';
  }
}

function testarConexao(){
  const token = document.getElementById('cw-token').value.trim();
  const lojaId = document.getElementById('cw-loja-id').value.trim();
  if(!token){document.getElementById('cw-token').classList.add('error');toast('Cole o token de API','error');return;}
  if(!lojaId){document.getElementById('cw-loja-id').classList.add('error');toast('Informe o ID da loja','error');return;}
  document.getElementById('cw-token').classList.remove('error');
  document.getElementById('cw-loja-id').classList.remove('error');

  const connBadge = document.getElementById('conn-status-badge');
  connBadge.innerHTML='<span class="conn-dot"></span> Testando…';
  connBadge.className='conn-status testing';
  document.getElementById('conn-loading').style.display='block';
  document.getElementById('conn-result').style.display='none';
  document.getElementById('btn-salvar-token').style.display='none';

  // Simula latência de API real
  setTimeout(()=>{
    document.getElementById('conn-loading').style.display='none';
    const result = document.getElementById('conn-result');
    result.style.display='block';
    // Simula resposta da API com dados da loja
    const loja = CW_MOCK.loja;
    result.innerHTML=`<div class="alert alert-ok">
      <span class="alert-icon">✓</span>
      <div>
        <div class="alert-title">Conexão estabelecida com sucesso</div>
        <div style="margin-top:6px;font-size:12px;display:grid;grid-template-columns:auto 1fr;gap:4px 12px">
          <span style="color:var(--text-3)">Estabelecimento:</span><strong>${loja.nome}</strong>
          <span style="color:var(--text-3)">Status:</span><span class="badge badge-green">${loja.status}</span>
          <span style="color:var(--text-3)">Horários:</span><span>${loja.horarios}</span>
          <span style="color:var(--text-3)">Pagamentos:</span><span>${loja.formasPagamento.join(', ')}</span>
        </div>
      </div>
    </div>`;
    CW.token = token;
    CW.lojaId = lojaId;
    document.getElementById('btn-salvar-token').style.display='flex';
    connBadge.innerHTML='<span class="conn-dot"></span> Pronto para salvar';
    connBadge.className='conn-status testing';
    addLog('conexao','✅','Teste de conexão bem-sucedido',`Loja: ${loja.nome}`);
  }, 1800);
}

function salvarToken(){
  CW.connected=true;
  updateConnBadge();
  document.getElementById('btn-salvar-token').style.display='none';
  toast('Integração ativada ✓ Token salvo neste navegador');
  addLog('token','🔐','Token salvo e integração ativada','Dados ficam apenas neste navegador');
}

function importarCatalogo(){
  if(!CW.connected){toast('Configure e salve o token primeiro','error');integTab('conexao',document.querySelectorAll('.integ-tab')[0]);return;}
  document.getElementById('catalogo-loading').style.display='block';
  document.getElementById('catalogo-content').innerHTML='';

  setTimeout(()=>{
    document.getElementById('catalogo-loading').style.display='none';
    const cat = CW_MOCK.catalogo;
    CW.catalogoImportado = cat;
    document.getElementById('cat-last-sync').textContent=new Date().toLocaleString('pt-BR');

    // Cruzar com produtos existentes no sistema
    const nomesComFicha = S.produtos.map(p=>(p.nome+' '+p.tamanho).toLowerCase());
    const semFicha = cat.filter(c=>c.status==='ativo' && !nomesComFicha.some(n=>c.nome.toLowerCase().includes(n.split(' ')[0].toLowerCase())));

    const rows = cat.map(c=>{
      const temFicha = nomesComFicha.some(n=>c.nome.toLowerCase().includes(n.split(' ')[0].toLowerCase()));
      const dotColor = c.status==='inativo'?'var(--text-3)':temFicha?'var(--green)':'var(--yellow)';
      const statusBadge = c.status==='inativo'?'<span class="badge badge-neutral">Inativo</span>':
        temFicha?'<span class="badge badge-green">Com ficha de custo</span>':
        '<span class="badge badge-yellow">⚠ Sem ficha</span>';
      return `<div class="catálogo-row">
        <span style="display:flex;align-items:center;gap:10px">
          <span class="status-dot" style="background:${dotColor}"></span>
          <span style="font-weight:500">${c.nome}</span>
        </span>
        <span style="display:flex;align-items:center;gap:14px">
          <span class="badge badge-neutral">${c.categoria}</span>
          <span style="font-variant-numeric:tabular-nums;font-weight:600;min-width:60px;text-align:right">${fmt(c.preco)}</span>
          ${statusBadge}
        </span>
      </div>`;
    }).join('');

    document.getElementById('catalogo-content').innerHTML=`<div>${rows}</div>`;

    // Atualiza preços dos produtos existentes com os preços do cardápio
    let atualizados=0;
    cat.forEach(c=>{
      S.produtos.forEach(p=>{
        if(c.nome.toLowerCase().includes(p.nome.toLowerCase()) && c.nome.toLowerCase().includes(p.tamanho.toLowerCase())){
          if(p.precoAtual!==c.preco){p.precoAtual=c.preco;atualizados++;}
        }
      });
    });

    addLog('catalogo','📋','Catálogo importado',`${cat.length} produtos · ${cat.filter(c=>c.status==='ativo').length} ativos · ${semFicha.length} sem ficha`);

    if(semFicha.length>0){
      document.getElementById('sem-ficha-alert')?.remove();
      const alertEl=document.createElement('div');
      alertEl.id='sem-ficha-alert';
      alertEl.className='alert alert-warn';
      alertEl.style.marginTop='16px';
      alertEl.innerHTML=`<span class="alert-icon">⚠️</span>
        <div><div class="alert-title">${semFicha.length} produto(s) sem ficha de custo</div>
        <div style="font-size:12px;margin-top:4px">${semFicha.map(s=>s.nome).join(', ')} — sem ficha cadastrada, o sistema não consegue calcular a margem desses itens.</div></div>`;
      document.getElementById('ip-catalogo').appendChild(alertEl);
    }
    toast(`${cat.length} produtos importados${atualizados>0?' · '+atualizados+' preços atualizados':''} ✓`);
  }, 2000);
}

function importarPedidos(){
  if(!CW.connected){toast('Configure e salve o token primeiro','error');integTab('conexao',document.querySelectorAll('.integ-tab')[0]);return;}
  const periodo = document.getElementById('ped-periodo').value;
  if(!periodo){toast('Selecione o período','error');return;}

  document.getElementById('pedidos-loading').style.display='block';
  document.getElementById('pedidos-content').innerHTML='';
  document.getElementById('pedidos-kpis').style.display='none';

  setTimeout(()=>{
    document.getElementById('pedidos-loading').style.display='none';
    const pedidos = CW_MOCK.pedidos(periodo);

    // KPIs
    const totalFat = pedidos.reduce((s,p)=>s+p.valor,0);
    const totalPed = pedidos.reduce((s,p)=>s+(p.numPedidos||0),0);
    const ticket = totalPed>0?totalFat/totalPed:0;
    document.getElementById('pk-total').textContent=totalPed.toLocaleString('pt-BR');
    document.getElementById('pk-fat').textContent=fmt(totalFat);
    document.getElementById('pk-ticket').textContent=fmt(ticket);
    document.getElementById('pedidos-kpis').style.display='block';

    // Volume por produto
    const volHtml = CW_MOCK.volumeProdutos.map(v=>{
      const cat = CW.catalogoImportado.find(c=>c.id===v.cwId);
      const nome = cat?cat.nome:'Produto #'+v.cwId;
      const pct = totalFat>0?(v.faturamento/totalFat*100):0;
      return `<tr>
        <td style="font-weight:500">${nome}</td>
        <td class="text-right td-mono">${v.qtd}</td>
        <td class="text-right td-mono">${fmt(v.faturamento)}</td>
        <td class="text-right">
          <div class="progress-bar" style="width:120px;display:inline-block">
            <div class="progress-fill" style="width:${Math.min(pct*3,100)}%;background:var(--accent)"></div>
          </div>
          <span style="font-size:11px;color:var(--text-3);margin-left:6px">${pct.toFixed(1)}%</span>
        </td>
      </tr>`;
    }).join('');

    document.getElementById('pedidos-content').innerHTML=`
      <div style="padding:16px 24px;border-bottom:1px solid var(--border)">
        <div style="font-size:12.5px;font-weight:600;margin-bottom:12px;color:var(--text-2)">VOLUME POR PRODUTO</div>
        <table>
          <thead><tr><th>Produto</th><th class="text-right">Qtde Vendida</th><th class="text-right">Faturamento</th><th class="text-right">% do Total</th></tr></thead>
          <tbody>${volHtml}</tbody>
        </table>
      </div>
      <div style="padding:16px 24px">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
          <div style="font-size:12.5px;font-weight:600;color:var(--text-2)">ENTRADAS A IMPORTAR NO FLUXO DE CAIXA</div>
          <button class="btn btn-primary btn-sm" onclick="confirmarImportacaoCaixa(${JSON.stringify(periodo).replace(/"/g,'&quot;')})">
            ↓ Inserir no Fluxo de Caixa (${pedidos.length} lançamentos)
          </button>
        </div>
        <div style="max-height:280px;overflow-y:auto;border:1px solid var(--border);border-radius:var(--r-sm)">
          <table>
            <thead><tr><th>Data</th><th>Descrição</th><th>Conta</th><th class="text-right">Valor</th></tr></thead>
            <tbody>
              ${pedidos.slice(0,20).map(p=>`<tr>
                <td style="font-size:12px;color:var(--text-3)">${p.data.split('-').reverse().join('/')}</td>
                <td style="font-weight:500">${p.desc}</td>
                <td><span class="badge badge-neutral" style="font-size:10px">${p.conta}</span></td>
                <td class="text-right td-mono" style="color:var(--green);font-weight:600">+${fmtN(p.valor)}</td>
              </tr>`).join('')}
              ${pedidos.length>20?`<tr><td colspan="4" style="text-align:center;color:var(--text-3);font-size:12px;padding:10px">… e mais ${pedidos.length-20} lançamentos</td></tr>`:''}
            </tbody>
          </table>
        </div>
      </div>`;

    // Store for confirmation
    CW._pendingPedidos = pedidos;
    addLog('pedidos','🛵','Pedidos buscados',`${periodo} · ${totalPed} pedidos · ${fmt(totalFat)}`);
    toast(`${pedidos.length} lançamentos prontos para importar ✓`);
  }, 2200);
}

function confirmarImportacaoCaixa(periodo){
  const pedidos = CW._pendingPedidos;
  if(!pedidos||pedidos.length===0) return;

  // Remove lançamentos CW anteriores do mesmo período para evitar duplicatas
  const removidos = S.lancamentos.filter(l=>l.fonte==='cardapio_web'&&l.data.startsWith(periodo));
  if(removidos.length>0){
    if(!confirm(`Já existem ${removidos.length} lançamentos do Cardápio Web para este período. Substituir?`)) return;
    S.lancamentos=S.lancamentos.filter(l=>!(l.fonte==='cardapio_web'&&l.data.startsWith(periodo)));
  }

  pedidos.forEach(p=>{
    S.lancamentos.push({...p,id:IDs.cx++});
  });

  const totalFat=pedidos.reduce((s,p)=>s+p.valor,0);
  addLog('caixa','✅','Pedidos inseridos no Fluxo de Caixa',`${pedidos.length} lançamentos · ${fmt(totalFat)}`);
  toast(`${pedidos.length} lançamentos inseridos no Fluxo de Caixa ✓`);
  CW._pendingPedidos=null;

  // Refresh button area
  document.getElementById('pedidos-content').querySelector('button').textContent='✓ Importado';
  document.getElementById('pedidos-content').querySelector('button').disabled=true;
  document.getElementById('pedidos-content').querySelector('button').style.background='var(--text-3)';
}

function addLog(tipo,icon,titulo,detalhe){
  CW.syncLog.unshift({tipo,icon,titulo,detalhe,ts:new Date()});
  renderSyncLog();
}

function renderSyncLog(){
  const el=document.getElementById('sync-log-content');
  if(!el) return;
  if(CW.syncLog.length===0){
    el.innerHTML='<div class="empty"><div class="empty-icon">🗂</div><div class="empty-title">Sem sincronizações ainda</div></div>';
    return;
  }
  el.innerHTML=CW.syncLog.map(l=>`
    <div class="sync-log-item">
      <div class="sync-icon" style="background:var(--surface-2)">${l.icon}</div>
      <div style="flex:1">
        <div style="font-size:13px;font-weight:500">${l.titulo}</div>
        <div style="font-size:11.5px;color:var(--text-3);margin-top:2px">${l.detalhe}</div>
      </div>
      <div style="font-size:11px;color:var(--text-3);white-space:nowrap">${l.ts.toLocaleString('pt-BR',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'})}</div>
    </div>`).join('');
}

function limparLog(){
  if(!confirm('Limpar histórico de sincronizações?')) return;
  CW.syncLog=[];renderSyncLog();toast('Histórico limpo');
}


// ═══ META ADS ════════════════════════════════════════════
const META = {
  connected: false,
  campanhas: [
    {id:1,nome:'Delivery Sexta & Sábado',status:'ativa',gasto:45.80,impressoes:4820,cliques:312,pedidos_gerados:8,faturamento_gerado:642,periodo:'últimos 7 dias'},
    {id:2,nome:'Promoção Pizza Família',status:'ativa',gasto:28.50,impressoes:2940,cliques:198,pedidos_gerados:4,faturamento_gerado:428,periodo:'últimos 7 dias'},
    {id:3,nome:'Remarketing — Clientes Antigos',status:'pausada',gasto:15.00,impressoes:1100,cliques:87,pedidos_gerados:2,faturamento_gerado:214,periodo:'últimos 7 dias'},
  ],
};

function renderMetaAds(){
  // Populate product selector
  const sel = document.getElementById('meta-produto-ref');
  if(sel && sel.options.length<=1){
    S.produtos.forEach(p=>{
      const opt=document.createElement('option');
      opt.value=p.id;
      opt.textContent=`${p.nome} ${p.tamanho} — R$${fmtN(p.precoAtual)}`;
      sel.appendChild(opt);
    });
  }
  renderMetaCampanhas();
}

function syncOrcamento(source){
  const slider=document.getElementById('meta-orcamento-slider');
  const input=document.getElementById('meta-orcamento-input');
  const display=document.getElementById('meta-orcamento-display');
  if(source==='slider'){input.value=slider.value;}
  else{slider.value=Math.min(500,Math.max(5,parseFloat(input.value)||50));}
  display.textContent='R$ '+parseInt(slider.value);
  calcBreakeven();
}

function calcBreakeven(){
  const orcamento=parseFloat(document.getElementById('meta-orcamento-input').value)||50;
  const prodId=parseInt(document.getElementById('meta-produto-ref').value);
  const res=document.getElementById('breakeven-result');
  const emp=document.getElementById('breakeven-empty');
  if(!prodId){res.style.display='none';emp.style.display='block';return;}
  const prod=S.produtos.find(p=>p.id===prodId);
  if(!prod){return;}
  const custoTotal=calcCustoTotal(prod);
  const margem=prod.precoAtual>0?(prod.precoAtual-custoTotal)/prod.precoAtual:0;
  if(margem<=0){
    emp.innerHTML='<span style="color:var(--red)">⚠ Produto com margem negativa — ajuste o preço antes de anunciar</span>';
    emp.style.display='block';res.style.display='none';return;
  }
  const breakeven=orcamento/margem;
  const unidades=Math.ceil(breakeven/prod.precoAtual);
  document.getElementById('be-valor').textContent=fmt(breakeven);
  document.getElementById('be-pizzas').innerHTML=`≈ <strong>${unidades} ${prod.nome} ${prod.tamanho}</strong> a mais do que você venderia sem o anúncio<br><span style="font-size:11px;color:var(--text-3)">Margem do produto: ${(margem*100).toFixed(1)}% · Custo total: ${fmt(custoTotal)}</span>`;
  res.style.display='block';emp.style.display='none';
}

function renderMetaCampanhas(){
  const wrap=document.getElementById('meta-campanhas-mock');
  if(!wrap)return;
  wrap.innerHTML=META.campanhas.map(c=>{
    // Get default breakeven for comparison
    const prodRef=S.produtos[1]; // Grande como referência
    const custoTotal=calcCustoTotal(prodRef);
    const margem=prodRef.precoAtual>0?(prodRef.precoAtual-custoTotal)/prodRef.precoAtual:0.35;
    const beNeeded=c.gasto/margem;
    const resultado=c.faturamento_gerado-beNeeded;
    const verdictClass=resultado>50?'ok':resultado>0?'warn':'bad';
    const verdictText=resultado>50
      ?`✓ Lucrou R$${fmtN(resultado)} acima do ponto de equilíbrio`
      :resultado>0
      ?`⚠ Cobriu o anúncio por R$${fmtN(resultado)} de margem`
      :`✗ Anúncio não se pagou — faltaram R$${fmtN(Math.abs(resultado))} em vendas`;
    const statusCls=c.status==='ativa'?'badge-green':'badge-neutral';
    const roas=c.gasto>0?(c.faturamento_gerado/c.gasto).toFixed(1):0;
    return `<div class="meta-campaign-card">
      <div class="meta-campaign-header">
        <div>
          <div class="meta-campaign-name">${c.nome}</div>
          <div style="font-size:11px;color:var(--text-3);margin-top:2px">${c.periodo}</div>
        </div>
        <span class="badge ${statusCls}">${c.status}</span>
      </div>
      <div class="meta-campaign-grid">
        <div class="meta-metric">
          <div class="meta-metric-val" style="color:var(--red)">${fmt(c.gasto)}</div>
          <div class="meta-metric-lbl">Gasto</div>
        </div>
        <div class="meta-metric">
          <div class="meta-metric-val" style="color:var(--green)">${fmt(c.faturamento_gerado)}</div>
          <div class="meta-metric-lbl">Faturamento Gerado</div>
        </div>
        <div class="meta-metric">
          <div class="meta-metric-val">${c.pedidos_gerados}</div>
          <div class="meta-metric-lbl">Pedidos</div>
        </div>
        <div class="meta-metric">
          <div class="meta-metric-val" style="color:${roas>=3?'var(--green)':roas>=1?'var(--yellow)':'var(--red)'}">${roas}x</div>
          <div class="meta-metric-lbl">ROAS <span class="tip"><span class="tip-icon">?</span><span class="tip-box">Retorno sobre o investimento em anúncio. 3x = para cada R$1 investido, R$3 em vendas geradas. Acima de 3x é considerado bom para restaurantes.</span></span></div>
        </div>
      </div>
      <div class="meta-verdict ${verdictClass}">${verdictText}</div>
    </div>`;
  }).join('');
}

function conectarMeta(){
  const token=document.getElementById('meta-token').value.trim();
  if(!token){toast('Cole o token de acesso do Meta','error');return;}
  const badge=document.getElementById('meta-conn-badge');
  badge.innerHTML='<span class="conn-dot"></span> Conectando…';
  badge.className='conn-status testing';
  setTimeout(()=>{
    META.connected=true;
    badge.innerHTML='<span class="conn-dot"></span> Conectado';
    badge.className='conn-status connected';
    toast('Meta Ads conectado ✓ Campanhas atualizadas');
    document.getElementById('meta-campanhas').querySelector('.alert')?.remove();
  },1800);
}

// ═══ FECHAMENTO DO MÊS ════════════════════════════════════
let closingCurrentStep=1;
const closingChecks=[
  {id:'c1',label:'Todas as vendas do mês lançadas',check:()=>S.lancamentos.filter(l=>l.tipo==='FL').length>0},
  {id:'c2',label:'Compras de ingredientes registradas',check:()=>S.lancamentos.filter(l=>l.tipo==='MP').length>0},
  {id:'c3',label:'Despesas fixas pagas registradas',check:()=>S.lancamentos.filter(l=>l.tipo==='FX').length>0},
  {id:'c4',label:'Taxas bancárias registradas',check:()=>S.lancamentos.filter(l=>l.tipo==='TX').length>0},
  {id:'c5',label:'Preços dos ingredientes atualizados',check:()=>true},
  {id:'c6',label:'Pró-labore do mês registrado',check:()=>S.prolabore.length>0},
];

function renderFechamento(){
  renderChecklist();
  renderFechamentoResumo();
}

function renderChecklist(){
  const cont=document.getElementById('checklist-container');
  if(!cont)return;
  const done=closingChecks.filter(c=>c.check()).length;
  cont.innerHTML=`<div style="margin-bottom:14px">
    <div style="display:flex;justify-content:space-between;font-size:12px;color:var(--text-3);margin-bottom:6px"><span>Progresso</span><span>${done}/${closingChecks.length} itens</span></div>
    <div class="progress-bar"><div class="progress-fill" style="width:${(done/closingChecks.length*100).toFixed(0)}%;background:var(--accent)"></div></div>
  </div>`
  +closingChecks.map(c=>{
    const ok=c.check();
    return `<div class="checklist-item">
      <div class="check-box ${ok?'checked':''}" onclick="this.classList.toggle('checked')">
        ${ok?'✓':''}
      </div>
      <span style="flex:1;${ok?'color:var(--text-3);text-decoration:line-through':''}">${c.label}</span>
      ${ok?'<span class="badge badge-green">✓</span>':'<span class="badge badge-yellow">Pendente</span>'}
    </div>`;
  }).join('');
}

function renderFechamentoResumo(){
  const el=document.getElementById('fechamento-resumo');
  if(!el)return;
  const lc=S.lancamentos;
  const entradas=lc.filter(l=>l.valor>0).reduce((s,l)=>s+l.valor,0);
  const saidas=lc.filter(l=>l.valor<0).reduce((s,l)=>s+Math.abs(l.valor),0);
  const tipos={FL:0,MP:0,FX:0,VA:0,TX:0,OP:0};
  lc.forEach(l=>{if(tipos[l.tipo]!==undefined)tipos[l.tipo]+=l.valor;});
  const TIPO_LABEL={FL:'Vendas',MP:'Ingredientes',FX:'Fixos',VA:'Variáveis',TX:'Taxas',OP:'Operacional'};
  el.innerHTML=`<div style="display:flex;flex-direction:column;gap:8px">
    ${Object.entries(tipos).filter(([,v])=>v!==0).map(([t,v])=>`
      <div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--border);font-size:13px">
        <span style="display:flex;align-items:center;gap:7px"><span class="tipo-badge tipo-${t}" style="width:22px;height:22px;font-size:8px">${t}</span>${TIPO_LABEL[t]}</span>
        <span style="font-weight:600;color:${v>=0?'var(--green)':'var(--red)'}">${v>=0?'+':''}${fmtN(v)}</span>
      </div>`).join('')}
    <div style="display:flex;justify-content:space-between;padding:8px 0;font-weight:700;font-size:14px;border-top:2px solid var(--text);margin-top:4px">
      <span>Resultado Líquido</span>
      <span style="color:${entradas-saidas>=0?'var(--green)':'var(--red)'}">${fmt(entradas-saidas)}</span>
    </div>
  </div>`;
}

function closingStep(n){
  closingCurrentStep=n;
  document.querySelectorAll('.closing-step').forEach((el,i)=>{
    el.classList.remove('active','done');
    if(i+1<n) el.classList.add('done');
    else if(i+1===n) el.classList.add('active');
  });
  document.querySelectorAll('.closing-panel').forEach((el,i)=>{
    el.classList.toggle('active',i+1===n);
  });
  if(n===3) renderRevisarCustos();
  if(n===4) renderReport();
}

function handleFileSelect(event){
  const files=Array.from(event.target.files);
  files.forEach(f=>addUploadedFile(f));
}
function handleDrop(event){
  event.preventDefault();
  document.getElementById('upload-zone').classList.remove('drag');
  const files=Array.from(event.dataTransfer.files);
  files.forEach(f=>addUploadedFile(f));
}
function addUploadedFile(file){
  const wrap=document.getElementById('uploaded-files');
  const url=URL.createObjectURL(file);
  const div=document.createElement('div');
  div.style.cssText='display:flex;align-items:center;gap:10px;padding:8px 10px;background:var(--surface-2);border-radius:6px;margin-bottom:6px;cursor:pointer;border:1px solid var(--border)';
  div.innerHTML=`<span style="font-size:16px">${file.type.includes('pdf')?'📄':'🖼'}</span>
    <span style="font-size:12.5px;font-weight:500;flex:1">${file.name}</span>
    <span style="font-size:11px;color:var(--text-3)">${(file.size/1024).toFixed(0)}KB</span>`;
  div.onclick=()=>previewFile(url,file.type);

  // Autofill fornecedor if name matches
  const known=S.lancamentos.map(l=>l.desc).filter(Boolean);
  const match=known.find(n=>file.name.toLowerCase().includes(n.toLowerCase().split(' ')[0]));
  if(match) document.getElementById('nf-fornecedor').value=match;

  wrap.appendChild(div);
  previewFile(url,file.type);
  // Populate fornecedores datalist
  const dl=document.getElementById('fornecedores-list');
  [...new Set(S.lancamentos.map(l=>l.desc))].forEach(n=>{
    const opt=document.createElement('option');opt.value=n;dl.appendChild(opt);
  });
}
function previewFile(url,type){
  const prev=document.getElementById('note-preview');
  if(type.includes('pdf')){
    prev.innerHTML=`<iframe src="${url}" style="width:100%;height:480px;border:none;border-radius:var(--r-sm)"></iframe>`;
  } else {
    prev.innerHTML=`<img src="${url}" style="max-width:100%;max-height:480px;object-fit:contain;border-radius:var(--r-sm)">`;
  }
  document.getElementById('nf-data').value=new Date().toISOString().split('T')[0];
}
function addFromNota(){
  const fornecedor=document.getElementById('nf-fornecedor').value.trim();
  const tipo=document.getElementById('nf-tipo').value;
  const valor=parseFloat(document.getElementById('nf-valor').value);
  const data=document.getElementById('nf-data').value;
  if(!fornecedor||isNaN(valor)||valor<=0||!data){toast('Preencha todos os campos','error');return;}
  S.lancamentos.push({id:IDs.cx++,data,tipo,desc:fornecedor,valor:-Math.abs(valor),conta:'Caixa'});
  document.getElementById('nf-fornecedor').value='';
  document.getElementById('nf-valor').value='';
  renderChecklist();
  toast(`Lançamento "${fornecedor}" adicionado ✓`);
}

function renderRevisarCustos(){
  // Ingredientes
  const ti=document.getElementById('tb-revisar-ingr');
  if(ti) ti.innerHTML=S.ingredientes.slice(0,15).map(i=>`<tr>
    <td style="font-weight:500">${i.nome} <span style="font-size:10.5px;color:var(--text-3)">(${i.unid})</span></td>
    <td class="text-right td-mono">${fmt(i.preco)}</td>
    <td class="text-right">
      <input type="number" value="${i.preco}" step="0.01" style="width:80px;text-align:right;padding:4px 6px;font-size:12px"
        onchange="updateIngrPrice(${i.id},this.value)">
    </td>
  </tr>`).join('');
  // Despesas
  const td=document.getElementById('tb-revisar-desp');
  if(td) td.innerHTML=S.despesas.map(d=>`<tr>
    <td>${d.desc}</td>
    <td class="text-right td-mono">${fmt(d.valor)}</td>
    <td class="text-right">
      <input type="number" value="${d.valor}" step="10" style="width:90px;text-align:right;padding:4px 6px;font-size:12px"
        onchange="updateDespValue(${d.id},this.value)">
    </td>
  </tr>`).join('');
}
function updateIngrPrice(id,val){
  const i=S.ingredientes.find(x=>x.id===id);
  if(!i)return;const p=parseFloat(val);
  if(!isNaN(p)&&p>0){i.precoAnt=i.preco;i.preco=p;toast('Preço atualizado ✓');}
}
function updateDespValue(id,val){
  const d=S.despesas.find(x=>x.id===id);
  if(!d)return;const p=parseFloat(val);
  if(!isNaN(p)&&p>0){d.valor=p;toast('Despesa atualizada ✓');}
}

function renderReport(){
  const lc=S.lancamentos;
  const entradas=lc.filter(l=>l.valor>0).reduce((s,l)=>s+l.valor,0);
  const saidas=lc.filter(l=>l.valor<0).reduce((s,l)=>s+Math.abs(l.valor),0);
  const cmv=lc.filter(l=>l.tipo==='MP').reduce((s,l)=>s+Math.abs(l.valor),0);
  const fixos=S.despesas.reduce((s,d)=>s+d.valor,0);
  const sal=S.salarios.reduce((s,d)=>s+d.salario*1.18,0);
  const pl=S.prolabore.reduce((s,d)=>s+d.valor,0);
  const imp=entradas*S.cfg.imposto;
  const lucro=entradas-cmv-fixos-sal-pl-imp;
  const now=new Date();
  const el=document.getElementById('report-preview');
  if(!el)return;

  // Group MP purchases by supplier
  const compras={};
  lc.filter(l=>l.tipo==='MP').forEach(l=>{compras[l.desc]=(compras[l.desc]||0)+Math.abs(l.valor);});

  el.innerHTML=`
    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:24px">
      <div>
        <div class="report-title">Relatório Gerencial Mensal</div>
        <div class="report-period">D'Luigi Pizzaria · Referência: Maio 2025 · Gerado em ${now.toLocaleDateString('pt-BR')}</div>
      </div>
      <div style="text-align:right;font-size:11px;color:var(--text-3)">
        <div style="font-weight:600;color:var(--text);font-size:13px">D'Luigi Pizzaria</div>
        <div>Simples Nacional · 6%</div>
        <div>Responsável: Sócio Responsável</div>
      </div>
    </div>

    <div class="report-section">
      <div class="report-section-title">DRE Simplificado</div>
      <div class="report-row"><span>Receita Bruta</span><span style="font-weight:600">${fmt(entradas)}</span></div>
      <div class="report-row" style="color:var(--red)"><span>(−) Impostos estimados (${(S.cfg.imposto*100).toFixed(0)}%)</span><span>− ${fmt(imp)}</span></div>
      <div class="report-row" style="color:var(--red)"><span>(−) Custo dos Ingredientes (CMV)</span><span>− ${fmt(cmv)}</span></div>
      <div class="report-row" style="color:var(--text-2)"><span>= Margem de Contribuição</span><span style="font-weight:600;color:var(--text)">${fmt(entradas-imp-cmv)}</span></div>
      <div class="report-row" style="color:var(--red)"><span>(−) Despesas Fixas Operacionais</span><span>− ${fmt(fixos)}</span></div>
      <div class="report-row" style="color:var(--red)"><span>(−) Folha de Pagamento c/ Encargos</span><span>− ${fmt(sal)}</span></div>
      <div class="report-row" style="color:var(--red)"><span>(−) Pró-labore dos Sócios</span><span>− ${fmt(pl)}</span></div>
      <div class="report-total"><span>Resultado Líquido do Período</span><span style="color:${lucro>=0?'var(--green)':'var(--red)'}">${lucro>=0?'+':''}${fmt(lucro)}</span></div>
    </div>

    <div class="report-section">
      <div class="report-section-title">Compras por Fornecedor (MP)</div>
      ${Object.entries(compras).map(([f,v])=>`<div class="report-row"><span>${f}</span><span>${fmt(v)}</span></div>`).join('')}
      <div class="report-total"><span>Total Compras</span><span>${fmt(cmv)}</span></div>
    </div>

    <div class="report-section">
      <div class="report-section-title">Despesas Fixas Detalhadas</div>
      ${S.despesas.map(d=>`<div class="report-row"><span>${d.desc}</span><span>${fmt(d.valor)}</span></div>`).join('')}
      <div class="report-total"><span>Total Despesas Fixas</span><span>${fmt(fixos)}</span></div>
    </div>

    <div class="report-section">
      <div class="report-section-title">Folha de Pagamento</div>
      ${S.salarios.map(s=>`<div class="report-row"><span>${s.func}</span><span>${fmt(s.salario*1.18)} <span style="font-size:11px;color:var(--text-3)">(c/ 18% encargos)</span></span></div>`).join('')}
      ${S.prolabore.map(p=>`<div class="report-row"><span>Pró-labore — ${p.nome}</span><span>${fmt(p.valor)}</span></div>`).join('')}
      <div class="report-total"><span>Total Folha + Pró-labore</span><span>${fmt(sal+pl)}</span></div>
    </div>

    <div style="margin-top:24px;padding-top:16px;border-top:1px solid var(--border);font-size:11px;color:var(--text-3)">
      Este relatório é de natureza gerencial e não substitui documentos contábeis oficiais. Os valores de imposto são estimativas baseadas no regime cadastrado no sistema.
    </div>`;
}

function imprimirRelatorio(){
  window.print();
}

// ═══ CATEGORIAS ══════════════════════════════════════════
const CATS = {
  tipos: {
    fixos: [{id:'FL',label:'Venda / Entrada 🔒'},{id:'MP',label:'Ingrediente (MP) 🔒'},{id:'FX',label:'Despesa Fixa 🔒'},{id:'VA',label:'Variável 🔒'},{id:'TX',label:'Taxa Bancária 🔒'},{id:'OP',label:'Operacional 🔒'}],
    custom: ['Manutenção','Investimento'],
  },
  contas: ['Caixa','Pix','Crédito','Débito','Sicoob PJ','Santander'],
  despcat: ['Infraestrutura','Pessoal','Marketing','Tecnologia','Logística','Financeiro'],
  prodcat: ['Pizzas','Bebidas','Porções','Sobremesas','Combos'],
};

function renderCategorias(){
  // Tipos fixos
  const tf=document.getElementById('tags-tipos-obrig');
  if(tf) tf.innerHTML=`<div class="cat-section-title">Categorias do Sistema (não editáveis)</div><div class="tag-list">`
    +CATS.tipos.fixos.map(t=>`<span class="tag-item" style="opacity:.7">${t.id} — ${t.label}</span>`).join('')
    +'</div>';
  renderTagList('tags-tipos-custom', CATS.tipos.custom, 'tipos');
  renderTagList('tags-contas', CATS.contas, 'contas');
  renderTagList('tags-desp-cat', CATS.despcat, 'despcat');
  renderTagList('tags-prod-cat', CATS.prodcat, 'prodcat');
}

function renderTagList(elId, arr, key){
  const el=document.getElementById(elId);
  if(!el)return;
  el.innerHTML=arr.map((t,i)=>`<span class="tag-item">
    ${t}
    <span class="tag-remove" onclick="removeTag('${key}',${i})">×</span>
  </span>`).join('');
}

function addTag(key){
  const inputMap={tipos:'new-tipo',contas:'new-conta',despcat:'new-desp-cat',prodcat:'new-prod-cat'};
  const input=document.getElementById(inputMap[key]);
  if(!input)return;
  const val=input.value.trim();
  if(!val){toast('Digite um nome para a categoria','error');return;}
  const arr=key==='tipos'?CATS.tipos.custom:CATS[key];
  if(arr.includes(val)){toast('Categoria já existe','error');return;}
  arr.push(val);
  input.value='';
  renderCategorias();
  // Update selects in caixa
  if(key==='contas') updateContaSelect();
  toast('Categoria adicionada ✓');
}

function removeTag(key, idx){
  const arr=key==='tipos'?CATS.tipos.custom:CATS[key];
  arr.splice(idx,1);
  renderCategorias();
  if(key==='contas') updateContaSelect();
  toast('Categoria removida');
}

function updateContaSelect(){
  const sel=document.getElementById('cx-conta');
  if(!sel)return;
  const current=sel.value;
  sel.innerHTML=CATS.contas.map(c=>`<option value="${c}" ${c===current?'selected':''}>${c}</option>`).join('');
}


document.addEventListener('DOMContentLoaded',()=>{
  document.getElementById('cx-data').value=new Date().toISOString().split('T')[0];
  recalcMarkup();
  renderDashboard();
});
</script>
</body>
</html>