<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Custo & Caixa — Gestão para Alimentação</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<style>
:root {
  --bg:#F5F3EF;--surface:#FFF;--surface-2:#F9F8F5;--surface-3:#F2F0EB;
  --text:#1C1C1E;--text-2:#6E6E73;--text-3:#AEAEB2;
  --accent:#2C6E49;--accent-2:#E8F2ED;--accent-warm:#BF6A2E;
  --red:#C0392B;--red-light:#FBEAE8;--green:#2C6E49;--green-light:#E8F2ED;
  --yellow:#D97706;--yellow-light:#FEF3C7;--blue:#0284C7;--blue-light:#E0F2FE;
  --border:rgba(0,0,0,0.07);--border-strong:rgba(0,0,0,0.12);
  --shadow-sm:0 1px 3px rgba(0,0,0,0.06),0 1px 2px rgba(0,0,0,0.04);
  --shadow:0 4px 16px rgba(0,0,0,0.07),0 1px 4px rgba(0,0,0,0.04);
  --shadow-lg:0 12px 40px rgba(0,0,0,0.10),0 4px 12px rgba(0,0,0,0.05);
  --r:14px;--r-sm:8px;--nav-w:228px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:15px}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;display:flex;-webkit-font-smoothing:antialiased}

/* SIDEBAR */
.sidebar{width:var(--nav-w);min-height:100vh;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;position:fixed;top:0;left:0;bottom:0;z-index:100;padding:0 0 24px}
.sidebar-brand{padding:26px 22px 20px;border-bottom:1px solid var(--border);margin-bottom:8px}
.brand-label{font-family:'Cormorant Garamond',serif;font-size:21px;font-weight:400;letter-spacing:-0.3px;color:var(--text);line-height:1}
.brand-sub{font-size:10.5px;color:var(--text-3);letter-spacing:0.08em;text-transform:uppercase;margin-top:4px;font-weight:500}
.nav-section{padding:0 10px;margin-bottom:2px}
.nav-section-label{font-size:10px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--text-3);padding:10px 10px 5px}
.nav-item{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:var(--r-sm);cursor:pointer;color:var(--text-2);font-size:13px;font-weight:400;transition:all .15s ease;user-select:none;position:relative}
.nav-item:hover{background:var(--surface-2);color:var(--text)}
.nav-item.active{background:var(--accent-2);color:var(--accent);font-weight:500}
.nav-icon{width:16px;height:16px;flex-shrink:0;opacity:.65}
.nav-item.active .nav-icon{opacity:1}
.nav-badge{margin-left:auto;background:var(--accent);color:white;font-size:9px;font-weight:700;padding:2px 6px;border-radius:10px}
.sidebar-footer{margin-top:auto;padding:0 12px}
.sidebar-biz{background:var(--bg);border-radius:var(--r-sm);padding:11px 13px;display:flex;align-items:center;gap:9px}
.biz-avatar{width:30px;height:30px;background:var(--accent);border-radius:7px;display:flex;align-items:center;justify-content:center;font-size:13px;color:white;font-weight:600;flex-shrink:0}
.biz-name{font-size:12.5px;font-weight:500;color:var(--text);line-height:1.2}
.biz-type{font-size:10.5px;color:var(--text-3)}

/* MAIN */
.main{margin-left:var(--nav-w);flex:1;min-height:100vh;display:flex;flex-direction:column}
.topbar{background:rgba(245,243,239,.9);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);border-bottom:1px solid var(--border);padding:14px 28px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50}
.topbar-title{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:400;color:var(--text)}
.topbar-meta{font-size:11.5px;color:var(--text-3);margin-top:1px}
.topbar-actions{display:flex;gap:9px;align-items:center}
.btn{display:inline-flex;align-items:center;gap:6px;padding:7px 15px;border-radius:var(--r-sm);font-size:12.5px;font-weight:500;cursor:pointer;border:none;transition:all .15s ease;font-family:'DM Sans',sans-serif;white-space:nowrap}
.btn-primary{background:var(--accent);color:white}.btn-primary:hover{background:#245A3C}
.btn-ghost{background:transparent;color:var(--text-2);border:1px solid var(--border-strong)}.btn-ghost:hover{background:var(--surface);color:var(--text)}
.btn-danger{background:var(--red-light);color:var(--red);border:none}.btn-danger:hover{background:#f5cdc9}
.btn-sm{padding:5px 11px;font-size:11.5px}
.btn-xs{padding:3px 8px;font-size:10.5px;border-radius:5px}
.content{padding:24px 28px;flex:1}

/* SECTIONS */
.section{display:none;animation:fadeUp .22s ease}
.section.active{display:block}
@keyframes fadeUp{from{opacity:0;transform:translateY(7px)}to{opacity:1;transform:translateY(0)}}

/* KPI */
.kpi-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px}
.kpi-card{background:var(--surface);border-radius:var(--r);padding:18px 20px;border:1px solid var(--border);box-shadow:var(--shadow-sm)}
.kpi-label{font-size:10.5px;color:var(--text-3);letter-spacing:.06em;text-transform:uppercase;font-weight:600;margin-bottom:7px;display:flex;align-items:center;gap:5px}
.kpi-value{font-family:'Cormorant Garamond',serif;font-size:26px;font-weight:400;color:var(--text);line-height:1}
.kpi-delta{font-size:11.5px;margin-top:5px;display:flex;align-items:center;gap:4px}
.kpi-delta.pos{color:var(--green)}.kpi-delta.neg{color:var(--red)}.kpi-delta.warn{color:var(--yellow)}
.kpi-bar{margin-top:9px;height:3px;background:var(--border);border-radius:2px;overflow:hidden}
.kpi-bar-fill{height:100%;border-radius:2px;transition:width .5s ease}

/* CARDS */
.card{background:var(--surface);border-radius:var(--r);border:1px solid var(--border);box-shadow:var(--shadow-sm);overflow:hidden;margin-bottom:18px}
.card-header{padding:16px 20px 12px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border)}
.card-title{font-size:13.5px;font-weight:600;color:var(--text)}
.card-sub{font-size:11.5px;color:var(--text-3);margin-top:2px}
.card-actions{display:flex;gap:8px;align-items:center;flex-shrink:0}

/* TABLE */
table{width:100%;border-collapse:collapse}
th{font-size:10.5px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text-3);padding:9px 20px;text-align:left;border-bottom:1px solid var(--border);background:var(--surface-2)}
td{padding:10px 20px;font-size:13px;color:var(--text);border-bottom:1px solid var(--border);vertical-align:middle}
tr:last-child td{border-bottom:none}
tr:hover td{background:var(--surface-2)}
.td-mono{font-variant-numeric:tabular-nums;font-weight:500}
.total-row td{font-weight:600;background:var(--surface-2)}

/* BADGE */
.badge{display:inline-flex;align-items:center;padding:2px 8px;border-radius:20px;font-size:10.5px;font-weight:600;letter-spacing:.02em}
.badge-green{background:var(--green-light);color:var(--green)}
.badge-red{background:var(--red-light);color:var(--red)}
.badge-yellow{background:var(--yellow-light);color:var(--yellow)}
.badge-blue{background:var(--blue-light);color:var(--blue)}
.badge-neutral{background:var(--surface-2);color:var(--text-2);border:1px solid var(--border)}
.badge-warm{background:#FDF0E6;color:var(--accent-warm)}

/* FORM */
.form-row{display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:12px;padding:18px 20px;border-bottom:1px solid var(--border);align-items:end}
.form-group{display:flex;flex-direction:column;gap:5px}
.form-label{font-size:10.5px;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--text-3);display:flex;align-items:center;gap:4px}
input,select,textarea{width:100%;padding:8px 11px;border:1px solid var(--border-strong);border-radius:var(--r-sm);font-family:'DM Sans',sans-serif;font-size:13px;color:var(--text);background:var(--surface);outline:none;transition:border-color .15s,box-shadow .15s}
input:focus,select:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(44,110,73,.1)}
input.error{border-color:var(--red)}
input[type="number"]{font-variant-numeric:tabular-nums}

/* CHARTS */
.charts-grid{display:grid;grid-template-columns:1.4fr 1fr;gap:14px;margin-bottom:20px}
.chart-wrap{background:var(--surface);border-radius:var(--r);border:1px solid var(--border);padding:18px 20px 12px;box-shadow:var(--shadow-sm)}
.chart-title{font-size:13px;font-weight:600;margin-bottom:14px;color:var(--text);display:flex;align-items:center;gap:6px}

/* PRODUTO CARDS */
.produtos-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:14px;margin-bottom:20px}
.produto-card{background:var(--surface);border-radius:var(--r);border:1px solid var(--border);box-shadow:var(--shadow-sm);overflow:hidden;transition:box-shadow .2s,transform .2s}
.produto-card:hover{box-shadow:var(--shadow);transform:translateY(-1px)}
.produto-card-header{padding:14px 16px 10px;background:linear-gradient(135deg,#F9F8F5 0%,#F0EEE8 100%);border-bottom:1px solid var(--border)}
.produto-name{font-family:'Cormorant Garamond',serif;font-size:17px;font-weight:500;color:var(--text);line-height:1.2}
.produto-tamanho{font-size:10.5px;color:var(--text-3);margin-top:2px}
.produto-body{padding:12px 16px}
.ingr-row{display:flex;justify-content:space-between;align-items:center;padding:4px 0;border-bottom:1px solid var(--border);font-size:12px}
.ingr-row:last-of-type{border-bottom:none}
.ingr-name{color:var(--text-2);flex:1}
.ingr-qtd{color:var(--text-3);font-size:10.5px;margin:0 7px}
.ingr-custo{color:var(--text);font-weight:500;font-variant-numeric:tabular-nums}
.produto-footer{padding:10px 16px;background:var(--surface-2);border-top:1px solid var(--border)}
.pf-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px}
.pf-label{font-size:9.5px;color:var(--text-3);font-weight:600;text-transform:uppercase;letter-spacing:.06em}
.pf-value{font-family:'Cormorant Garamond',serif;font-size:17px;font-weight:500;color:var(--text)}
.pf-value.accent{color:var(--accent)}

/* CAIXA */
.caixa-grid{display:grid;grid-template-columns:1fr 320px;gap:14px}
.tipo-badge{display:inline-flex;align-items:center;justify-content:center;width:26px;height:26px;border-radius:5px;font-size:9px;font-weight:700;letter-spacing:.04em;flex-shrink:0}
.tipo-FL{background:var(--green-light);color:var(--green)}
.tipo-TX{background:#FDF0E6;color:var(--accent-warm)}
.tipo-MP{background:#EEF2FF;color:#4F46E5}
.tipo-FX{background:var(--red-light);color:var(--red)}
.tipo-VA{background:#FDF4FF;color:#9333EA}
.tipo-OP{background:var(--blue-light);color:var(--blue)}
.saldo-display{text-align:center;padding:22px 18px;border-bottom:1px solid var(--border)}
.saldo-label{font-size:10.5px;color:var(--text-3);text-transform:uppercase;letter-spacing:.08em;font-weight:600;margin-bottom:6px}
.saldo-value{font-family:'Cormorant Garamond',serif;font-size:38px;font-weight:300;letter-spacing:-1px}
.saldo-value.pos{color:var(--green)}.saldo-value.neg{color:var(--red)}
.resumo-conta{padding:10px 16px;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--border);font-size:12.5px}
.resumo-conta:last-child{border-bottom:none}
.conta-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}

/* DESP GRID */
.desp-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}

/* PREP CARD */
.prep-card{background:var(--surface);border-radius:var(--r);border:1px solid var(--border);box-shadow:var(--shadow-sm);overflow:hidden}
.prep-header{padding:14px 16px 10px;background:linear-gradient(135deg,#F0F4FF,#E8EDF8);border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.prep-name{font-family:'Cormorant Garamond',serif;font-size:16px;font-weight:500}
.prep-body{padding:10px 16px 14px}
.prep-ingr-row{display:flex;justify-content:space-between;font-size:11.5px;padding:3px 0;color:var(--text-2)}
.prep-footer{padding:10px 16px;background:var(--surface-2);border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center}

/* VENDA DIRETA */
.vd-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:12px;margin-bottom:20px}
.vd-card{background:var(--surface);border-radius:var(--r);border:1px solid var(--border);box-shadow:var(--shadow-sm);padding:14px 16px;transition:box-shadow .2s}
.vd-card:hover{box-shadow:var(--shadow)}
.vd-name{font-weight:500;font-size:13.5px;margin-bottom:2px}
.vd-category{font-size:10.5px;color:var(--text-3);margin-bottom:10px}
.vd-row{display:flex;justify-content:space-between;font-size:12px;padding:3px 0;border-bottom:1px solid var(--border)}
.vd-row:last-of-type{border-bottom:none}

/* TOOLTIP */
.tip{position:relative;display:inline-flex;align-items:center;cursor:help}
.tip-icon{width:13px;height:13px;border-radius:50%;background:var(--text-3);color:white;font-size:8px;font-weight:700;display:inline-flex;align-items:center;justify-content:center;flex-shrink:0}
.tip-box{display:none;position:absolute;bottom:calc(100% + 6px);left:50%;transform:translateX(-50%);background:var(--text);color:white;font-size:11px;padding:7px 10px;border-radius:7px;white-space:nowrap;max-width:220px;white-space:normal;line-height:1.4;z-index:200;box-shadow:var(--shadow-lg);font-weight:400;pointer-events:none}
.tip-box::after{content:'';position:absolute;top:100%;left:50%;transform:translateX(-50%);border:5px solid transparent;border-top-color:var(--text)}
.tip:hover .tip-box{display:block}

/* ONBOARDING */
#onboarding{position:fixed;inset:0;background:rgba(28,28,30,.6);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);z-index:500;display:flex;align-items:center;justify-content:center;animation:fadeIn .3s ease}
#onboarding.hidden{display:none}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
.ob-card{background:var(--surface);border-radius:20px;width:480px;max-width:90vw;box-shadow:var(--shadow-lg);overflow:hidden}
.ob-top{padding:32px 36px 0;text-align:center}
.ob-logo{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:400;color:var(--text);margin-bottom:6px}
.ob-tagline{font-size:13px;color:var(--text-3)}
.ob-steps{display:flex;gap:0;margin:24px 0 0;border-top:1px solid var(--border)}
.ob-step{flex:1;padding:22px 20px;text-align:center;border-right:1px solid var(--border);position:relative;cursor:pointer;transition:background .15s}
.ob-step:last-child{border-right:none}
.ob-step.active{background:var(--accent-2)}
.ob-step-num{width:28px;height:28px;border-radius:50%;background:var(--border);color:var(--text-3);font-size:12px;font-weight:600;display:flex;align-items:center;justify-content:center;margin:0 auto 8px}
.ob-step.active .ob-step-num{background:var(--accent);color:white}
.ob-step.done .ob-step-num{background:var(--green-light);color:var(--green)}
.ob-step-title{font-size:11.5px;font-weight:600;color:var(--text);margin-bottom:4px}
.ob-step-sub{font-size:10.5px;color:var(--text-3);line-height:1.4}
.ob-step.active .ob-step-title{color:var(--accent)}
.ob-bottom{padding:20px 36px 28px;background:var(--surface-2);border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.ob-hint{font-size:12px;color:var(--text-2);line-height:1.5;flex:1;margin-right:20px}

/* ALERT BANNERS */
.alert{border-radius:var(--r-sm);padding:10px 14px;font-size:12.5px;display:flex;align-items:flex-start;gap:9px;margin-bottom:14px}
.alert-icon{font-size:14px;flex-shrink:0;margin-top:1px}
.alert-warn{background:var(--yellow-light);color:#92400E;border:1px solid #FCD34D}
.alert-info{background:var(--blue-light);color:#075985;border:1px solid #BAE6FD}
.alert-ok{background:var(--green-light);color:#14532D;border:1px solid #BBF7D0}
.alert-title{font-weight:600;margin-bottom:2px}

/* PROGRESS BAR */
.progress-wrap{margin:6px 0}
.progress-label{display:flex;justify-content:space-between;font-size:11px;color:var(--text-3);margin-bottom:4px}
.progress-bar{height:6px;background:var(--border);border-radius:3px;overflow:hidden}
.progress-fill{height:100%;border-radius:3px;transition:width .5s ease}

/* SEARCH */
.search-wrap{position:relative}
.search-wrap input{padding-left:32px;width:200px}
.search-icon{position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--text-3);font-size:13px;pointer-events:none}

/* MISC */
.pill-tabs{display:flex;gap:3px;background:var(--surface-2);border-radius:var(--r-sm);padding:3px;border:1px solid var(--border);width:fit-content}
.pill-tab{padding:5px 14px;border-radius:6px;font-size:12px;font-weight:500;color:var(--text-2);cursor:pointer;transition:all .15s;user-select:none}
.pill-tab.active{background:var(--surface);color:var(--text);box-shadow:var(--shadow-sm)}
.section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:10px}
.text-right{text-align:right}.text-center{text-align:center}
.muted{color:var(--text-3)}
.divider{height:1px;background:var(--border);margin:4px 0}
.highlight-row td{background:var(--accent-2)!important}
.empty{text-align:center;padding:40px 24px;color:var(--text-3)}
.empty-icon{font-size:28px;margin-bottom:10px}
.empty-title{font-size:14px;font-weight:500;color:var(--text-2);margin-bottom:5px}
.empty-sub{font-size:12px}
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--border-strong);border-radius:4px}

/* TOAST */
#toast{position:fixed;bottom:22px;right:22px;background:var(--text);color:white;padding:11px 18px;border-radius:var(--r-sm);font-size:12.5px;font-weight:500;box-shadow:var(--shadow-lg);transform:translateY(70px);opacity:0;transition:all .3s cubic-bezier(.34,1.56,.64,1);z-index:999;pointer-events:none;max-width:320px}
#toast.show{transform:translateY(0);opacity:1}
#toast.error{background:var(--red)}

/* PRICE HISTORY */
.hist-chip{display:inline-flex;align-items:center;gap:4px;font-size:10px;color:var(--text-3);margin-left:6px}
.hist-chip.up{color:var(--red)}.hist-chip.down{color:var(--green)}

/* META ADS MODULE */
.meta-hero{background:linear-gradient(135deg,#1877F2 0%,#0D5FCC 100%);border-radius:var(--r);padding:28px 32px;color:white;margin-bottom:20px;position:relative;overflow:hidden}
.meta-hero::before{content:'';position:absolute;right:-40px;top:-40px;width:200px;height:200px;border-radius:50%;background:rgba(255,255,255,.06)}
.meta-hero-title{font-family:'Cormorant Garamond',serif;font-size:26px;font-weight:400;margin-bottom:6px}
.meta-hero-sub{font-size:13px;opacity:.8;line-height:1.5}
.breakeven-display{background:var(--surface);border-radius:var(--r);border:1px solid var(--border);padding:28px;box-shadow:var(--shadow-sm);margin-bottom:20px}
.breakeven-result{text-align:center;padding:24px;background:linear-gradient(135deg,var(--accent-2),#fff);border-radius:var(--r-sm);border:1px solid rgba(44,110,73,.15);margin:16px 0}
.breakeven-num{font-family:'Cormorant Garamond',serif;font-size:52px;font-weight:300;color:var(--accent);line-height:1}
.breakeven-label{font-size:12px;color:var(--text-2);margin-top:4px;font-weight:500}
.breakeven-pizza{font-size:13px;color:var(--text-2);margin-top:10px;padding-top:10px;border-top:1px solid var(--border)}
.meta-campaign-card{background:var(--surface);border-radius:var(--r);border:1px solid var(--border);padding:18px 20px;margin-bottom:12px;box-shadow:var(--shadow-sm)}
.meta-campaign-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px}
.meta-campaign-name{font-weight:600;font-size:14px}
.meta-campaign-status{font-size:11px;font-weight:600;padding:3px 9px;border-radius:20px}
.meta-campaign-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
.meta-metric{text-align:center;padding:10px;background:var(--surface-2);border-radius:var(--r-sm)}
.meta-metric-val{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:500}
.meta-metric-lbl{font-size:10px;color:var(--text-3);text-transform:uppercase;letter-spacing:.05em;margin-top:2px}
.meta-verdict{margin-top:12px;padding:10px 14px;border-radius:var(--r-sm);font-size:12.5px;display:flex;align-items:center;gap:8px}
.meta-verdict.ok{background:var(--green-light);color:var(--green)}
.meta-verdict.bad{background:var(--red-light);color:var(--red)}
.meta-verdict.warn{background:var(--yellow-light);color:var(--yellow)}
.budget-slider-wrap{margin:14px 0}
.budget-slider{width:100%;-webkit-appearance:none;height:4px;border-radius:2px;background:var(--border);outline:none}
.budget-slider::-webkit-slider-thumb{-webkit-appearance:none;width:18px;height:18px;border-radius:50%;background:var(--accent);cursor:pointer;box-shadow:0 1px 4px rgba(0,0,0,.2)}

/* MONTHLY CLOSING */
.closing-steps{display:flex;gap:0;margin-bottom:24px}
.closing-step{flex:1;padding:14px 16px;background:var(--surface);border:1px solid var(--border);border-right:none;position:relative;cursor:pointer;transition:background .15s}
.closing-step:first-child{border-radius:var(--r-sm) 0 0 var(--r-sm)}
.closing-step:last-child{border-right:1px solid var(--border);border-radius:0 var(--r-sm) var(--r-sm) 0}
.closing-step.active{background:var(--accent-2);border-color:rgba(44,110,73,.25)}
.closing-step.done{background:var(--green-light)}
.closing-step-num{width:24px;height:24px;border-radius:50%;background:var(--border);color:var(--text-3);font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center;margin-bottom:6px}
.closing-step.active .closing-step-num{background:var(--accent);color:white}
.closing-step.done .closing-step-num{background:var(--green);color:white}
.closing-step-title{font-size:12px;font-weight:600;color:var(--text-2)}
.closing-step.active .closing-step-title{color:var(--accent)}
.closing-step.done .closing-step-title{color:var(--green)}
.closing-panel{display:none}.closing-panel.active{display:block}
.upload-zone{border:2px dashed var(--border-strong);border-radius:var(--r);padding:40px 24px;text-align:center;cursor:pointer;transition:all .2s;background:var(--surface-2)}
.upload-zone:hover,.upload-zone.drag{border-color:var(--accent);background:var(--accent-2)}
.upload-zone-icon{font-size:32px;margin-bottom:10px}
.note-viewer{display:grid;grid-template-columns:1fr 1fr;gap:16px;min-height:400px}
.note-preview{background:var(--surface-2);border-radius:var(--r-sm);border:1px solid var(--border);overflow:hidden;display:flex;align-items:center;justify-content:center;position:relative}
.note-preview img{max-width:100%;max-height:480px;object-fit:contain}
.checklist-item{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid var(--border);font-size:13px}
.checklist-item:last-child{border-bottom:none}
.check-box{width:20px;height:20px;border-radius:5px;border:2px solid var(--border-strong);cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .15s}
.check-box.checked{background:var(--accent);border-color:var(--accent);color:white}
.report-preview{background:white;border-radius:var(--r);border:1px solid var(--border);padding:32px;box-shadow:var(--shadow)}
.report-title{font-family:'Cormorant Garamond',serif;font-size:24px;font-weight:400;margin-bottom:4px}
.report-period{font-size:12px;color:var(--text-3);margin-bottom:24px}
.report-section{margin-bottom:20px}
.report-section-title{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:var(--text-3);margin-bottom:8px;padding-bottom:6px;border-bottom:2px solid var(--text)}
.report-row{display:flex;justify-content:space-between;padding:5px 0;font-size:13px;border-bottom:1px solid var(--border)}
.report-row:last-child{border-bottom:none}
.report-total{display:flex;justify-content:space-between;padding:8px 0;font-size:14px;font-weight:700;border-top:2px solid var(--text);margin-top:4px}

/* FREE CATEGORIES */
.tag-list{display:flex;flex-wrap:wrap;gap:6px;margin-top:8px}
.tag-item{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;background:var(--surface-2);border:1px solid var(--border);border-radius:20px;font-size:12px;color:var(--text-2)}
.tag-remove{cursor:pointer;color:var(--text-3);font-size:14px;line-height:1;transition:color .1s}
.tag-remove:hover{color:var(--red)}
.tag-add-row{display:flex;gap:8px;margin-top:8px}
.tag-add-row input{flex:1}
.cat-section{padding:18px 20px;border-bottom:1px solid var(--border)}
.cat-section:last-child{border-bottom:none}
.cat-section-title{font-size:12px;font-weight:600;color:var(--text-2);text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px}

/* INTEGRATION MODULE */
.integ-tabs{display:flex;border-bottom:1px solid var(--border);background:var(--surface);margin-bottom:0}
.integ-tab{padding:11px 20px;font-size:12.5px;font-weight:500;color:var(--text-2);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;transition:all .15s;user-select:none}
.integ-tab.active{color:var(--accent);border-bottom-color:var(--accent)}
.integ-tab:hover:not(.active){color:var(--text)}
.integ-panel{display:none;padding:24px 0 0}.integ-panel.active{display:block}
.conn-card{background:var(--surface);border-radius:var(--r);border:1px solid var(--border);padding:28px 32px;max-width:560px;box-shadow:var(--shadow-sm)}
.conn-status{display:inline-flex;align-items:center;gap:7px;padding:5px 12px;border-radius:20px;font-size:12px;font-weight:600}
.conn-status.connected{background:var(--green-light);color:var(--green)}
.conn-status.disconnected{background:var(--red-light);color:var(--red)}
.conn-status.testing{background:var(--yellow-light);color:var(--yellow)}
.conn-dot{width:7px;height:7px;border-radius:50%;background:currentColor;animation:none}
.conn-status.testing .conn-dot{animation:pulse 1s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.sync-log-item{display:flex;align-items:flex-start;gap:12px;padding:12px 20px;border-bottom:1px solid var(--border)}
.sync-log-item:last-child{border-bottom:none}
.sync-icon{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}
.import-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:20px}
.import-card{background:var(--surface);border-radius:var(--r);border:1px solid var(--border);padding:18px 20px;box-shadow:var(--shadow-sm)}
.import-card-title{font-size:12px;font-weight:600;color:var(--text-2);text-transform:uppercase;letter-spacing:.05em;margin-bottom:4px}
.import-card-value{font-family:'Cormorant Garamond',serif;font-size:28px;font-weight:400;color:var(--text)}
.import-card-sub{font-size:11px;color:var(--text-3);margin-top:3px}
.catálogo-row{display:flex;align-items:center;justify-content:space-between;padding:10px 20px;border-bottom:1px solid var(--border);font-size:13px}
.catálogo-row:last-child{border-bottom:none}
.catálogo-row:hover{background:var(--surface-2)}
.status-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.sidebar-conn-badge{display:inline-flex;align-items:center;gap:4px;font-size:9.5px;font-weight:600;padding:2px 7px;border-radius:10px;margin-left:auto}
.sidebar-conn-badge.on{background:var(--green-light);color:var(--green)}
.sidebar-conn-badge.off{background:var(--red-light);color:var(--red)}
.loading-bar{height:3px;background:var(--border);border-radius:2px;overflow:hidden;margin:8px 0}
.loading-fill{height:100%;background:var(--accent);border-radius:2px;animation:loading 1.5s ease infinite}
@keyframes loading{0%{width:0%;margin-left:0}50%{width:60%;margin-left:20%}100%{width:0%;margin-left:100%}}
</style>
</head>
<body>

<!-- ══ ONBOARDING ══ -->
<div id="onboarding">
  <div class="ob-card">
    <div class="ob-top">
      <div class="ob-logo">Custo &amp; Caixa</div>
      <div class="ob-tagline">Gestão financeira para quem cuida da comida, não de planilhas.</div>
    </div>
    <div class="ob-steps">
      <div class="ob-step active" id="ob-step-1">
        <div class="ob-step-num">1</div>
        <div class="ob-step-title">Configure o negócio</div>
        <div class="ob-step-sub">Regime tributário, faturamento esperado e lucro desejado</div>
      </div>
      <div class="ob-step" id="ob-step-2">
        <div class="ob-step-num">2</div>
        <div class="ob-step-title">Cadastre ingredientes</div>
        <div class="ob-step-sub">Preço de cada item que você compra para produzir</div>
      </div>
      <div class="ob-step" id="ob-step-3">
        <div class="ob-step-num">3</div>
        <div class="ob-step-title">Monte as fichas</div>
        <div class="ob-step-sub">O sistema calcula o preço certo de cada produto automaticamente</div>
      </div>
    </div>
    <div class="ob-bottom">
      <div class="ob-hint" id="ob-hint">
        <strong>Por onde começar?</strong> Primeiro diga ao sistema quanto você fatura por mês e qual regime de imposto usa. Com isso, o cálculo de preços vai ser preciso desde o início.
      </div>
      <div style="display:flex;flex-direction:column;gap:8px;align-items:flex-end">
        <button class="btn btn-primary" onclick="obNext()">Começar →</button>
        <button class="btn btn-ghost btn-sm" onclick="closeOb()">Já conheço o sistema</button>
      </div>
    </div>
  </div>
</div>

<!-- ══ SIDEBAR ══ -->
<nav class="sidebar">
  <div class="sidebar-brand">
    <div class="brand-label">Custo &amp; Caixa</div>
    <div class="brand-sub">Gestão para Alimentação</div>
  </div>

  <div class="nav-section">
    <div class="nav-section-label">Visão Geral</div>
    <div class="nav-item active" onclick="nav('dashboard',this)">
      <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      Dashboard
    </div>
  </div>

  <div class="nav-section">
    <div class="nav-section-label">Estrutura de Custos</div>
    <div class="nav-item" onclick="nav('ingredientes',this)">
      <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
      Ingredientes
    </div>
    <div class="nav-item" onclick="nav('preparacoes',this)">
      <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
      Preparações
    </div>
    <div class="nav-item" onclick="nav('produtos',this)">
      <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path d="M12 6v6l4 2m6-2a10 10 0 11-20 0 10 10 0 0120 0z"/></svg>
      Fichas de Custo
    </div>
    <div class="nav-item" onclick="nav('vendadireta',this)">
      <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
      Venda Direta
    </div>
    <div class="nav-item" onclick="nav('despesas',this)">
      <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
      Despesas &amp; Salários
    </div>
  </div>

  <div class="nav-section">
    <div class="nav-section-label">Financeiro</div>
    <div class="nav-item" onclick="nav('caixa',this)">
      <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      Fluxo de Caixa
    </div>
    <div class="nav-item" onclick="nav('fechamento',this)">
      <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
      Fechamento do Mês
    </div>
  </div>

  <div class="nav-section">
    <div class="nav-section-label">Tráfego Pago</div>
    <div class="nav-item" onclick="nav('metaads',this)">
      <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
      Meta Ads
    </div>
  </div>

  <div class="nav-section">
    <div class="nav-section-label">Configurações</div>
    <div class="nav-item" onclick="nav('categorias',this)">
      <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
      Categorias
    </div>
  </div>

  <div class="nav-section">
    <div class="nav-section-label">Integrações</div>
    <div class="nav-item" onclick="nav('integracao',this)" id="nav-integracao">
      <svg class="nav-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
      Cardápio Web
      <span class="sidebar-conn-badge off" id="sidebar-badge">✗ Off</span>
    </div>
  </div>

  <div class="sidebar-footer">
    <div class="sidebar-biz">
      <div class="biz-avatar">D</div>
      <div>
        <div class="biz-name">D'Luigi</div>
        <div class="biz-type">Pizzaria · Simples 6%</div>
      </div>
    </div>
  </div>
</nav>

<!-- ══ MAIN ══ -->
<div class="main">
  <div class="topbar">
    <div>
      <div class="topbar-title" id="page-title">Dashboard</div>
      <div class="topbar-meta" id="page-meta">Maio 2025 · Visão Geral</div>
    </div>
    <div class="topbar-actions">
      <button class="btn btn-ghost btn-sm" onclick="exportCSV()">↑ Exportar CSV</button>
      <button class="btn btn-primary btn-sm" id="btn-add" onclick="handleAdd()">+ Adicionar</button>
    </div>
  </div>

  <div class="content">

    <!-- ════ DASHBOARD ════ -->
    <section class="section active" id="sec-dashboard">
      <div id="dashboard-alerts"></div>
      <div class="kpi-grid">
        <div class="kpi-card">
          <div class="kpi-label">
            Faturamento Bruto
            <span class="tip"><span class="tip-icon">?</span><span class="tip-box">Total de vendas do período registradas no fluxo de caixa (entradas do tipo Venda).</span></span>
          </div>
          <div class="kpi-value" id="kpi-fat">—</div>
          <div class="kpi-delta pos" id="kpi-fat-d">Mês atual</div>
          <div class="kpi-bar"><div class="kpi-bar-fill" style="width:72%;background:var(--accent)"></div></div>
        </div>
        <div class="kpi-card">
          <div class="kpi-label">
            Custo dos Insumos
            <span class="tip"><span class="tip-icon">?</span><span class="tip-box">Quanto você gastou em matéria-prima (ingredientes, embalagens). Ideal ficar abaixo de 35% do faturamento em pizzarias.</span></span>
          </div>
          <div class="kpi-value" id="kpi-cmv">—</div>
          <div class="kpi-delta" id="kpi-cmv-pct">—</div>
          <div class="kpi-bar"><div class="kpi-bar-fill" id="kpi-cmv-bar" style="background:var(--accent-warm)"></div></div>
        </div>
        <div class="kpi-card">
          <div class="kpi-label">
            Custos Fixos + Equipe
            <span class="tip"><span class="tip-icon">?</span><span class="tip-box">Soma de aluguel, contas, salários e pró-labore. Esses custos existem mesmo que você não venda nada no mês.</span></span>
          </div>
          <div class="kpi-value" id="kpi-desp">—</div>
          <div class="kpi-delta" id="kpi-desp-pct">—</div>
          <div class="kpi-bar"><div class="kpi-bar-fill" id="kpi-desp-bar" style="background:var(--red)"></div></div>
        </div>
        <div class="kpi-card">
          <div class="kpi-label">
            Lucro Estimado
            <span class="tip"><span class="tip-icon">?</span><span class="tip-box">Faturamento menos custo dos insumos e despesas fixas. Valor positivo = sobra dinheiro. Negativo = prejuízo.</span></span>
          </div>
          <div class="kpi-value" id="kpi-lucro">—</div>
          <div class="kpi-delta" id="kpi-lucro-pct">—</div>
          <div class="kpi-bar"><div class="kpi-bar-fill" id="kpi-lucro-bar" style="background:var(--accent)"></div></div>
        </div>
      </div>

      <div class="charts-grid">
        <div class="chart-wrap">
          <div class="chart-title">Entradas e Saídas por Dia</div>
          <canvas id="chartFluxo" height="155"></canvas>
        </div>
        <div class="chart-wrap">
          <div class="chart-title">
            Para onde vai cada real?
            <span class="tip"><span class="tip-icon">?</span><span class="tip-box">De cada R$1,00 que entra, veja quanto vai para insumos, custos fixos e sobra como lucro.</span></span>
          </div>
          <canvas id="chartCustos" height="155"></canvas>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <div>
            <div class="card-title">Análise de Margem por Produto</div>
            <div class="card-sub">Quanto sobra de lucro em cada pizza vendida</div>
          </div>
        </div>
        <table>
          <thead><tr>
            <th>Produto</th><th>Tamanho</th>
            <th>Custo dos Ingredientes <span class="tip"><span class="tip-icon">?</span><span class="tip-box">Soma do custo de cada ingrediente usado nessa pizza.</span></span></th>
            <th>Custo Total* <span class="tip"><span class="tip-icon">?</span><span class="tip-box">Custo dos ingredientes + parte proporcional dos custos fixos e salários.</span></span></th>
            <th>Preço Praticado</th>
            <th>Margem</th>
            <th>Situação</th>
          </tr></thead>
          <tbody id="tb-analise"></tbody>
        </table>
        <div style="padding:10px 20px;font-size:11px;color:var(--text-3);border-top:1px solid var(--border)">
          *Custo total inclui rateio proporcional de despesas fixas, salários e encargos sobre a projeção de vendas.
        </div>
      </div>
    </section>

    <!-- ════ INGREDIENTES ════ -->
    <section class="section" id="sec-ingredientes">
      <div class="alert alert-info" style="margin-bottom:16px">
        <span class="alert-icon">💡</span>
        <div><div class="alert-title">Dica de uso</div>Cadastre aqui tudo que você compra para produzir. Mantenha os preços atualizados sempre que receber uma nota nova — isso garante que os preços dos produtos fiquem corretos automaticamente.</div>
      </div>
      <div class="card">
        <div class="card-header">
          <div><div class="card-title">Ingredientes Diretos</div><div class="card-sub">Itens com custo identificável por produto (mussarela, presunto, massa…)</div></div>
          <div class="card-actions">
            <div class="search-wrap"><span class="search-icon">⌕</span><input type="text" id="busca-ingr" placeholder="Buscar…" oninput="filtrarIngredientes()"></div>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group"><label class="form-label">Nome do Ingrediente</label><input type="text" id="ingr-nome" placeholder="Ex: Mussarela"></div>
          <div class="form-group"><label class="form-label">Unidade</label>
            <select id="ingr-unid"><option value="kg">kg</option><option value="unidade">unidade</option><option value="litro">litro</option><option value="pacote">pacote</option><option value="cx">caixa</option></select>
          </div>
          <div class="form-group">
            <label class="form-label">Preço Atual (R$) <span class="tip"><span class="tip-icon">?</span><span class="tip-box">Preço de compra por unidade de medida. Ex: se o kg de mussarela custa R$32, coloque 32.</span></span></label>
            <input type="number" id="ingr-preco" placeholder="0,00" step="0.01" min="0">
          </div>
          <div class="form-group" style="justify-content:flex-end"><button class="btn btn-primary" onclick="addIngrediente()">+ Adicionar</button></div>
        </div>
        <table>
          <thead><tr><th>Ingrediente</th><th>Unidade</th><th class="text-right">Preço Atual</th><th class="text-right">Último Preço</th><th class="text-right">Variação</th><th class="text-right">Ações</th></tr></thead>
          <tbody id="tb-ingredientes"></tbody>
        </table>
      </div>

      <div class="card">
        <div class="card-header">
          <div><div class="card-title">Ingredientes Indiretos</div><div class="card-sub">Embalagens e descartáveis — difíceis de medir por produto, então rateados pelo total produzido no mês</div></div>
          <button class="btn btn-ghost btn-sm" onclick="addIndir()">+ Adicionar</button>
        </div>
        <table>
          <thead><tr><th>Item</th><th>Unidade</th><th class="text-right">Preço/Un</th><th class="text-right">Qtde Média/Mês</th><th class="text-right">Custo Mensal</th><th class="text-right">Custo por Unidade Vendida</th></tr></thead>
          <tbody id="tb-indir"></tbody>
          <tfoot><tr class="total-row"><td colspan="4" class="text-right" style="color:var(--text-2)">Total Mensal:</td><td class="text-right td-mono" id="total-indir">—</td><td class="text-right td-mono muted" id="total-indir-un">—</td></tr></tfoot>
        </table>
      </div>
    </section>

    <!-- ════ PREPARAÇÕES ════ -->
    <section class="section" id="sec-preparacoes">
      <div class="alert alert-info" style="margin-bottom:16px">
        <span class="alert-icon">🍕</span>
        <div><div class="alert-title">O que são Preparações?</div>São itens que você faz na cozinha antes de montar os produtos finais. Ex: a massa de pizza, o molho de tomate, o strogonoff. Elas têm um custo próprio que entra nas fichas dos produtos.</div>
      </div>
      <div id="grid-preps" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:14px"></div>
    </section>

    <!-- ════ PRODUTOS ════ -->
    <section class="section" id="sec-produtos">
      <div class="section-header">
        <div class="pill-tabs" id="tabs-produtos">
          <div class="pill-tab active" onclick="filtrarProdutos('todos',this)">Todos</div>
          <div class="pill-tab" onclick="filtrarProdutos('familia',this)">Família</div>
          <div class="pill-tab" onclick="filtrarProdutos('grande',this)">Grande</div>
          <div class="pill-tab" onclick="filtrarProdutos('broto',this)">Broto</div>
        </div>
        <div style="display:flex;align-items:center;gap:10px;font-size:12.5px;color:var(--text-2)">
          <span class="tip">
            Divisor de preço (markup)
            <span class="tip-icon" style="margin-left:4px">?</span>
            <span class="tip-box">Este número diz quanto do preço de venda vai para cobrir os custos. Se você coloca 37,5%, significa que para cada R$100 que entra, R$37,50 pagam os custos do produto. O sistema calcula o preço certo automaticamente.</span>
          </span>
          <span style="font-weight:700;color:var(--accent);font-size:16px" id="markup-display">37,5%</span>
          <span style="font-size:11px;color:var(--text-3)">(definido em Despesas)</span>
        </div>
      </div>
      <div class="produtos-grid" id="grid-produtos"></div>
    </section>

    <!-- ════ VENDA DIRETA ════ -->
    <section class="section" id="sec-vendadireta">
      <div class="alert alert-info" style="margin-bottom:16px">
        <span class="alert-icon">🥤</span>
        <div><div class="alert-title">O que é Venda Direta?</div>Produtos que você compra prontos e revende: refrigerantes, cervejas, água, vinhos. Eles têm um markup diferente das pizzas porque a margem nesses itens costuma ser maior.</div>
      </div>
      <div class="card">
        <div class="card-header">
          <div><div class="card-title">Produtos de Revenda</div><div class="card-sub">Comprados prontos e vendidos sem transformação</div></div>
          <div class="card-actions">
            <div style="display:flex;align-items:center;gap:8px;font-size:12.5px">
              <span style="color:var(--text-2)">Markup bebidas:</span>
              <input type="number" id="markup-bebidas" value="40" style="width:60px;text-align:center;font-weight:600" oninput="renderVendaDireta()">
              <span style="color:var(--text-3)">%</span>
            </div>
            <button class="btn btn-ghost btn-sm" onclick="addVendaDireta()">+ Produto</button>
          </div>
        </div>
        <table>
          <thead><tr>
            <th>Produto</th><th>Categoria</th>
            <th class="text-right">Custo de Compra</th>
            <th class="text-right">Preço Sugerido</th>
            <th class="text-right">Preço Praticado</th>
            <th class="text-right">Lucro/Un</th>
            <th class="text-right">Previsão Mensal</th>
            <th class="text-right">Lucro Previsto/Mês</th>
            <th></th>
          </tr></thead>
          <tbody id="tb-vd"></tbody>
          <tfoot><tr class="total-row">
            <td colspan="7" class="text-right" style="color:var(--text-2)">Total Lucro Previsto/Mês:</td>
            <td class="text-right td-mono" id="total-vd-lucro">—</td>
            <td></td>
          </tr></tfoot>
        </table>
      </div>
    </section>

    <!-- ════ DESPESAS ════ -->
    <section class="section" id="sec-despesas">
      <div class="desp-grid">
        <div>
          <div class="card">
            <div class="card-header">
              <div><div class="card-title">Despesas Fixas do Negócio</div><div class="card-sub">Custos que você paga todo mês independente de quanto vende</div></div>
              <button class="btn btn-ghost btn-sm" onclick="addDespesa()">+ Adicionar</button>
            </div>
            <table>
              <thead><tr>
                <th>Descrição</th>
                <th class="text-right">Valor/Mês</th>
                <th class="text-right">
                  Custo por R$1 vendido
                  <span class="tip"><span class="tip-icon">?</span><span class="tip-box">De cada R$1,00 que você vende, quanto desse valor vai para pagar essa despesa.</span></span>
                </th>
                <th></th>
              </tr></thead>
              <tbody id="tb-desp"></tbody>
              <tfoot><tr class="total-row"><td>Total Fixos</td><td class="text-right td-mono" id="total-desp-val">—</td><td class="text-right td-mono" id="total-desp-rat">—</td><td></td></tr></tfoot>
            </table>
          </div>

          <div class="card">
            <div class="card-header">
              <div><div class="card-title">Pró-Labore (Retirada do Sócio)</div><div class="card-sub">O que o dono retira mensalmente — separado dos salários da equipe</div></div>
            </div>
            <div class="form-row" style="grid-template-columns:1fr 1fr auto;align-items:end">
              <div class="form-group"><label class="form-label">Nome do Sócio</label><input type="text" id="pl-nome" placeholder="Ex: Maria"></div>
              <div class="form-group"><label class="form-label">Retirada Mensal (R$)</label><input type="number" id="pl-valor" placeholder="0,00" step="100"></div>
              <button class="btn btn-primary" onclick="addProlabore()" style="margin-bottom:1px">+ Adicionar</button>
            </div>
            <table>
              <thead><tr><th>Sócio</th><th class="text-right">Retirada Mensal</th><th></th></tr></thead>
              <tbody id="tb-prolabore"></tbody>
              <tfoot><tr class="total-row"><td>Total Pró-Labore</td><td class="text-right td-mono" id="total-pl">—</td><td></td></tr></tfoot>
            </table>
          </div>
        </div>

        <div>
          <div class="card">
            <div class="card-header"><div><div class="card-title">Mão de Obra (Equipe)</div><div class="card-sub">Salários + 18% de encargos trabalhistas</div></div></div>
            <table>
              <thead><tr><th>Função</th><th class="text-right">Salário</th><th class="text-right">Com Encargos</th></tr></thead>
              <tbody id="tb-salarios"></tbody>
              <tfoot><tr class="total-row"><td>Total Equipe</td><td class="text-right td-mono" id="total-sal">—</td><td class="text-right td-mono" id="total-sal-enc">—</td></tr></tfoot>
            </table>
          </div>

          <div class="card" style="margin-top:0">
            <div class="card-header"><div class="card-title">Configurações do Negócio</div></div>
            <div style="padding:16px 20px;display:flex;flex-direction:column;gap:14px">
              <div class="form-group">
                <label class="form-label">
                  Faturamento esperado por mês (R$)
                  <span class="tip"><span class="tip-icon">?</span><span class="tip-box">Quanto você espera vender por mês. Esse número é usado para calcular quanto de cada custo fixo está embutido em cada produto vendido.</span></span>
                </label>
                <input type="number" id="cfg-projecao" value="90000" oninput="recalcTudo()">
              </div>
              <div class="form-group">
                <label class="form-label">Regime de Imposto</label>
                <select id="cfg-regime" onchange="recalcTudo()">
                  <option value="0.06">Simples Nacional — 6%</option>
                  <option value="0.12">Regime Normal — ICMS 12%</option>
                  <option value="0.0925">PIS/COFINS — 9,25%</option>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">
                  Lucro desejado (%)
                  <span class="tip"><span class="tip-icon">?</span><span class="tip-box">Quanto % do preço de venda você quer que sobre como lucro. Para pizzarias, de 8% a 15% é considerado saudável.</span></span>
                </label>
                <input type="number" id="cfg-lucro" value="10" step="1" min="0" max="100" oninput="recalcTudo()">
              </div>
              <div style="background:var(--surface-2);border-radius:var(--r-sm);padding:14px 16px;border:1px solid var(--border)">
                <div style="font-size:10.5px;color:var(--text-3);font-weight:600;text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px">
                  Divisor de Preço Calculado
                  <span class="tip"><span class="tip-icon">?</span><span class="tip-box">Calculado como: 1 − (imposto + lucro desejado). Divide o custo de ingredientes por esse número para chegar no preço de venda correto.</span></span>
                </div>
                <div style="font-family:'Cormorant Garamond',serif;font-size:34px;font-weight:400;color:var(--accent)" id="markup-calc">—</div>
                <div style="font-size:11px;color:var(--text-3);margin-top:3px">Fórmula: 1 − (impostos + lucro)</div>
              </div>
              <div style="background:var(--surface-2);border-radius:var(--r-sm);padding:14px 16px;border:1px solid var(--border)">
                <div style="font-size:10.5px;color:var(--text-3);font-weight:600;text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px">Distribuição dos Custos</div>
                <div id="cost-breakdown"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ════ FLUXO DE CAIXA ════ -->
    <section class="section" id="sec-caixa">
      <div class="caixa-grid">
        <div>
          <div class="card" style="margin-bottom:16px">
            <div class="card-header">
              <div><div class="card-title">Registrar Movimentação</div><div class="card-sub">Entradas e saídas do dia</div></div>
            </div>
            <div class="form-row">
              <div class="form-group"><label class="form-label">Data</label><input type="date" id="cx-data"></div>
              <div class="form-group">
                <label class="form-label">
                  Tipo
                  <span class="tip"><span class="tip-icon">?</span><span class="tip-box">FL = venda / entrada · MP = compra de ingrediente · FX = despesa fixa (aluguel, luz…) · VA = despesa variável · TX = taxa bancária · OP = operacional</span></span>
                </label>
                <select id="cx-tipo">
                  <option value="FL">Venda / Entrada (FL)</option>
                  <option value="MP">Compra de Ingrediente (MP)</option>
                  <option value="FX">Despesa Fixa (FX)</option>
                  <option value="VA">Despesa Variável (VA)</option>
                  <option value="TX">Taxa Bancária (TX)</option>
                  <option value="OP">Operacional (OP)</option>
                </select>
              </div>
              <div class="form-group"><label class="form-label">Descrição</label><input type="text" id="cx-desc" placeholder="Ex: Vendas em Dinheiro"></div>
              <div class="form-group"><label class="form-label">Valor (R$)</label><input type="number" id="cx-valor" placeholder="0,00" step="0.01" min="0"></div>
              <div class="form-group"><label class="form-label">Conta</label>
                <select id="cx-conta">
                  <option value="Caixa">Caixa (Dinheiro)</option>
                  <option value="Pix">Pix</option>
                  <option value="Crédito">Cartão Crédito</option>
                  <option value="Débito">Cartão Débito</option>
                  <option value="Sicoob PJ">Sicoob PJ</option>
                  <option value="Santander">Santander</option>
                </select>
              </div>
              <div class="form-group" style="justify-content:flex-end"><button class="btn btn-primary" onclick="addLancamento()">Lançar</button></div>
            </div>
          </div>

          <div class="card">
            <div class="card-header">
              <div class="card-title">Extrato do Mês</div>
              <div style="display:flex;gap:6px;flex-wrap:wrap">
                <button class="btn btn-ghost btn-xs" onclick="filtrarCaixa('todos',this)" id="fcx-todos" style="background:var(--surface-3)">Todos</button>
                <button class="btn btn-ghost btn-xs" onclick="filtrarCaixa('FL',this)">Vendas</button>
                <button class="btn btn-ghost btn-xs" onclick="filtrarCaixa('MP',this)">Ingredientes</button>
                <button class="btn btn-ghost btn-xs" onclick="filtrarCaixa('FX',this)">Fixos</button>
                <button class="btn btn-ghost btn-xs" onclick="filtrarCaixa('VA',this)">Variáveis</button>
              </div>
            </div>
            <div style="max-height:420px;overflow-y:auto">
              <table>
                <thead><tr><th>Tipo</th><th>Data</th><th>Descrição</th><th>Conta</th><th class="text-right">Valor</th><th class="text-right">Saldo Acum.</th><th></th></tr></thead>
                <tbody id="tb-caixa"></tbody>
              </table>
            </div>
          </div>
        </div>

        <div>
          <div class="card">
            <div class="saldo-display">
              <div class="saldo-label">Saldo do Período</div>
              <div class="saldo-value pos" id="saldo-total">R$ 0,00</div>
            </div>
            <div style="padding:14px 16px 10px;border-bottom:1px solid var(--border)">
              <div style="font-size:10.5px;color:var(--text-3);font-weight:600;text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px">Saldo por Conta</div>
              <div id="resumo-contas"></div>
            </div>
            <div style="padding:14px 16px">
              <div style="font-size:10.5px;color:var(--text-3);font-weight:600;text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px">Por Tipo de Movimentação</div>
              <div id="resumo-tipos"></div>
              <canvas id="chartCaixa" style="margin-top:14px" height="120"></canvas>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ════ META ADS ════ -->
    <section class="section" id="sec-metaads">
      <div class="meta-hero">
        <div class="meta-hero-title">Calculadora de Tráfego Pago</div>
        <div class="meta-hero-sub">Descubra quanto seu anúncio precisa faturar para valer a pena — baseado no custo real dos seus produtos.</div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px">

        <!-- Calculadora -->
        <div class="breakeven-display">
          <div style="font-size:14px;font-weight:600;margin-bottom:4px">Quanto vou gastar no anúncio?</div>
          <div style="font-size:12px;color:var(--text-3);margin-bottom:16px">Arraste o slider ou digite o valor do orçamento diário</div>
          <div style="display:flex;gap:10px;align-items:center;margin-bottom:8px">
            <span style="font-size:28px;font-weight:300;font-family:'Cormorant Garamond',serif;color:var(--accent)" id="meta-orcamento-display">R$ 50</span>
            <input type="number" id="meta-orcamento-input" value="50" min="5" max="500" step="5"
              style="width:90px;font-size:15px;font-weight:600;text-align:center"
              oninput="syncOrcamento('input')">
          </div>
          <div class="budget-slider-wrap">
            <input type="range" class="budget-slider" id="meta-orcamento-slider" min="5" max="500" step="5" value="50" oninput="syncOrcamento('slider')">
            <div style="display:flex;justify-content:space-between;font-size:10px;color:var(--text-3);margin-top:4px"><span>R$5</span><span>R$500</span></div>
          </div>

          <div style="margin:16px 0 10px;font-size:12px;font-weight:600;color:var(--text-2)">Produto referência para o cálculo:</div>
          <select id="meta-produto-ref" style="width:100%;margin-bottom:16px" onchange="calcBreakeven()">
            <option value="">— Selecione um produto —</option>
          </select>

          <div class="breakeven-result" id="breakeven-result" style="display:none">
            <div style="font-size:11px;color:var(--text-3);font-weight:600;text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px">Para cobrir o anúncio, você precisa vender pelo menos:</div>
            <div class="breakeven-num" id="be-valor">R$ 0</div>
            <div class="breakeven-label">em pedidos extras gerados pelo anúncio</div>
            <div class="breakeven-pizza" id="be-pizzas"></div>
          </div>

          <div id="breakeven-empty" style="text-align:center;padding:20px;color:var(--text-3);font-size:13px">
            Selecione um produto acima para calcular
          </div>

          <div style="margin-top:16px;padding:14px;background:var(--surface-2);border-radius:var(--r-sm);border:1px solid var(--border)">
            <div style="font-size:11px;font-weight:600;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px">Como é calculado</div>
            <div style="font-size:12px;color:var(--text-2);line-height:1.6">
              <strong>Ponto de equilíbrio</strong> = Orçamento do anúncio ÷ Margem do produto<br>
              Se a margem da pizza é 35% e você gastou R$50, precisa de R$143 em vendas extras para cobrir o anúncio. Acima disso, cada real é lucro.
            </div>
          </div>
        </div>

        <!-- Conexão Meta + Campanhas -->
        <div>
          <div class="card" style="margin-bottom:14px">
            <div class="card-header">
              <div><div class="card-title">Conectar ao Meta Ads</div><div class="card-sub">Puxa o resultado real das campanhas ativas</div></div>
              <span class="conn-status disconnected" id="meta-conn-badge"><span class="conn-dot"></span> Desconectado</span>
            </div>
            <div style="padding:18px 20px">
              <div class="form-group" style="margin-bottom:12px">
                <label class="form-label">Token de Acesso (Meta Marketing API)</label>
                <input type="password" id="meta-token" placeholder="EAAxxxxxxxxxxxxxxx" style="font-family:monospace;font-size:12px">
              </div>
              <div class="form-group" style="margin-bottom:16px">
                <label class="form-label">ID da Conta de Anúncio</label>
                <input type="text" id="meta-account-id" placeholder="act_123456789">
              </div>
              <div style="display:flex;gap:8px">
                <button class="btn btn-primary btn-sm" onclick="conectarMeta()">Conectar</button>
                <button class="btn btn-ghost btn-sm" onclick="window.open('https://developers.facebook.com/tools/explorer','_blank')">Gerar Token ↗</button>
              </div>
            </div>
          </div>

          <div style="font-size:12.5px;font-weight:600;color:var(--text-2);margin-bottom:10px;text-transform:uppercase;letter-spacing:.06em;font-size:10.5px">Campanhas Ativas — Últimos 7 dias</div>
          <div id="meta-campanhas">
            <div class="alert alert-info">
              <span class="alert-icon">ℹ️</span>
              <div>Configure o token acima para ver o desempenho real das suas campanhas — ou use os dados simulados abaixo para entender o formato.</div>
            </div>
            <!-- Mock campanhas -->
            <div id="meta-campanhas-mock"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ════ FECHAMENTO DO MÊS ════ -->
    <section class="section" id="sec-fechamento">
      <div class="alert alert-info" style="margin-bottom:20px">
        <span class="alert-icon">📅</span>
        <div><div class="alert-title">Fluxo de uso mensal</div>Abra este módulo uma vez por mês. O sistema guia você pelos 4 passos para fechar o mês, subir as notas e gerar o relatório para o contador.</div>
      </div>

      <div class="closing-steps" id="closing-steps">
        <div class="closing-step active" id="cs-1" onclick="closingStep(1)">
          <div class="closing-step-num">1</div>
          <div class="closing-step-title">Verificar lançamentos</div>
        </div>
        <div class="closing-step" id="cs-2" onclick="closingStep(2)">
          <div class="closing-step-num">2</div>
          <div class="closing-step-title">Subir notas fiscais</div>
        </div>
        <div class="closing-step" id="cs-3" onclick="closingStep(3)">
          <div class="closing-step-num">3</div>
          <div class="closing-step-title">Revisar custos</div>
        </div>
        <div class="closing-step" id="cs-4" onclick="closingStep(4)">
          <div class="closing-step-num">4</div>
          <div class="closing-step-title">Relatório para contador</div>
        </div>
      </div>

      <!-- Passo 1: Verificar lançamentos -->
      <div class="closing-panel active" id="cp-1">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px">
          <div class="card">
            <div class="card-header"><div class="card-title">Checklist do Mês</div></div>
            <div style="padding:16px 20px" id="checklist-container"></div>
            <div style="padding:12px 20px;border-top:1px solid var(--border)">
              <button class="btn btn-primary" onclick="closingStep(2)">Próximo → Notas Fiscais</button>
            </div>
          </div>
          <div class="card">
            <div class="card-header"><div class="card-title">Resumo do Período</div><div style="font-size:12px;color:var(--text-3)">Lançamentos registrados</div></div>
            <div style="padding:16px 20px" id="fechamento-resumo"></div>
          </div>
        </div>
      </div>

      <!-- Passo 2: Notas Fiscais -->
      <div class="closing-panel" id="cp-2">
        <div class="note-viewer" id="note-viewer-wrap">
          <div>
            <div class="upload-zone" id="upload-zone" onclick="document.getElementById('file-upload').click()"
              ondragover="event.preventDefault();this.classList.add('drag')"
              ondragleave="this.classList.remove('drag')"
              ondrop="handleDrop(event)">
              <input type="file" id="file-upload" accept="image/*,application/pdf" multiple style="display:none" onchange="handleFileSelect(event)">
              <div class="upload-zone-icon">📎</div>
              <div style="font-size:14px;font-weight:500;margin-bottom:6px">Arraste notas fiscais aqui</div>
              <div style="font-size:12px;color:var(--text-3)">Ou clique para selecionar · JPG, PNG, PDF</div>
            </div>
            <div id="uploaded-files" style="margin-top:14px"></div>
          </div>
          <div class="card" style="margin:0">
            <div class="card-header"><div class="card-title">Preencher a partir da nota</div><div class="card-sub">Veja a nota ao lado e preencha os campos</div></div>
            <div class="note-preview" id="note-preview" style="min-height:280px;margin:12px">
              <div style="text-align:center;color:var(--text-3);font-size:13px"><div style="font-size:28px;margin-bottom:8px">🧾</div>Selecione uma nota para visualizar</div>
            </div>
            <div class="form-row" style="border-top:1px solid var(--border)">
              <div class="form-group"><label class="form-label">Fornecedor</label><input type="text" id="nf-fornecedor" placeholder="Ex: Mart Minas" list="fornecedores-list"><datalist id="fornecedores-list"></datalist></div>
              <div class="form-group"><label class="form-label">Tipo</label>
                <select id="nf-tipo"><option value="MP">Ingrediente (MP)</option><option value="FX">Despesa Fixa (FX)</option><option value="VA">Variável (VA)</option><option value="OP">Operacional (OP)</option></select>
              </div>
              <div class="form-group"><label class="form-label">Valor (R$)</label><input type="number" id="nf-valor" step="0.01" placeholder="0,00"></div>
              <div class="form-group"><label class="form-label">Data</label><input type="date" id="nf-data"></div>
              <div class="form-group" style="justify-content:flex-end"><button class="btn btn-primary" onclick="addFromNota()">+ Lançar</button></div>
            </div>
          </div>
        </div>
        <div style="margin-top:16px;display:flex;gap:10px">
          <button class="btn btn-ghost" onclick="closingStep(1)">← Voltar</button>
          <button class="btn btn-primary" onclick="closingStep(3)">Próximo → Revisar Custos</button>
        </div>
      </div>

      <!-- Passo 3: Revisar custos -->
      <div class="closing-panel" id="cp-3">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
          <div class="card">
            <div class="card-header"><div class="card-title">Ingredientes — atualizar preços</div><div class="card-sub">Algum preço mudou este mês?</div></div>
            <div style="max-height:380px;overflow-y:auto">
              <table>
                <thead><tr><th>Ingrediente</th><th class="text-right">Preço Atual</th><th class="text-right">Atualizar</th></tr></thead>
                <tbody id="tb-revisar-ingr"></tbody>
              </table>
            </div>
          </div>
          <div class="card">
            <div class="card-header"><div class="card-title">Despesas — confirmar valores</div><div class="card-sub">Alguma despesa fixa mudou?</div></div>
            <div style="max-height:380px;overflow-y:auto">
              <table>
                <thead><tr><th>Despesa</th><th class="text-right">Valor</th><th class="text-right">Editar</th></tr></thead>
                <tbody id="tb-revisar-desp"></tbody>
              </table>
            </div>
          </div>
        </div>
        <div style="margin-top:16px;display:flex;gap:10px">
          <button class="btn btn-ghost" onclick="closingStep(2)">← Voltar</button>
          <button class="btn btn-primary" onclick="closingStep(4)">Próximo → Gerar Relatório</button>
        </div>
      </div>

      <!-- Passo 4: Relatório -->
      <div class="closing-panel" id="cp-4">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px">
          <div style="font-size:14px;font-weight:600">Relatório Gerencial — pronto para enviar ao contador</div>
          <div style="display:flex;gap:10px">
            <button class="btn btn-ghost" onclick="closingStep(3)">← Voltar</button>
            <button class="btn btn-primary" onclick="imprimirRelatorio()">🖨 Imprimir / PDF</button>
          </div>
        </div>
        <div class="report-preview" id="report-preview"></div>
      </div>
    </section>

    <!-- ════ CATEGORIAS ════ -->
    <section class="section" id="sec-categorias">
      <div class="alert alert-info" style="margin-bottom:20px">
        <span class="alert-icon">🏷</span>
        <div><div class="alert-title">Categorias personalizadas</div>Adicione ou remova categorias de acordo com o seu negócio. As categorias marcadas com 🔒 são obrigatórias para o cálculo de custos.</div>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
        <div class="card">
          <div class="card-header"><div class="card-title">Tipos de Custo (Fluxo de Caixa)</div><div class="card-sub">Categorias para classificar movimentações</div></div>
          <div class="cat-section">
            <div id="tags-tipos-obrig"></div>
            <div style="margin-top:12px">
              <div class="cat-section-title">Categorias Personalizadas</div>
              <div class="tag-list" id="tags-tipos-custom"></div>
              <div class="tag-add-row">
                <input type="text" id="new-tipo" placeholder="Nova categoria (ex: Manutenção)" maxlength="20">
                <button class="btn btn-primary btn-sm" onclick="addTag('tipos')">+ Adicionar</button>
              </div>
            </div>
          </div>
        </div>

        <div class="card">
          <div class="card-header"><div class="card-title">Contas Bancárias</div><div class="card-sub">Contas e formas de pagamento usadas</div></div>
          <div class="cat-section">
            <div class="tag-list" id="tags-contas"></div>
            <div class="tag-add-row" style="margin-top:12px">
              <input type="text" id="new-conta" placeholder="Nova conta (ex: Nubank PJ)" maxlength="20">
              <button class="btn btn-primary btn-sm" onclick="addTag('contas')">+ Adicionar</button>
            </div>
          </div>
        </div>

        <div class="card">
          <div class="card-header"><div class="card-title">Categorias de Despesa</div><div class="card-sub">Agrupamentos para o relatório do contador</div></div>
          <div class="cat-section">
            <div class="tag-list" id="tags-desp-cat"></div>
            <div class="tag-add-row" style="margin-top:12px">
              <input type="text" id="new-desp-cat" placeholder="Nova categoria (ex: Marketing)" maxlength="20">
              <button class="btn btn-primary btn-sm" onclick="addTag('despcat')">+ Adicionar</button>
            </div>
          </div>
        </div>

        <div class="card">
          <div class="card-header"><div class="card-title">Categorias de Produto</div><div class="card-sub">Tipos de produto no cardápio</div></div>
          <div class="cat-section">
            <div class="tag-list" id="tags-prod-cat"></div>
            <div class="tag-add-row" style="margin-top:12px">
              <input type="text" id="new-prod-cat" placeholder="Nova categoria (ex: Sobremesas)" maxlength="20">
              <button class="btn btn-primary btn-sm" onclick="addTag('prodcat')">+ Adicionar</button>
            </div>
          </div>
        </div>
      </div>
    </section>


    <section class="section" id="sec-integracao">
      <div class="card" style="margin-bottom:20px">
        <div class="integ-tabs">
          <div class="integ-tab active" onclick="integTab('conexao',this)">🔌 Conexão</div>
          <div class="integ-tab" onclick="integTab('catalogo',this)">📋 Catálogo</div>
          <div class="integ-tab" onclick="integTab('pedidos',this)">🛵 Pedidos</div>
          <div class="integ-tab" onclick="integTab('log',this)">🗂 Histórico</div>
        </div>

        <!-- Conexão -->
        <div class="integ-panel active" id="ip-conexao" style="padding:28px">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;align-items:start">
            <div>
              <div style="font-size:15px;font-weight:600;margin-bottom:6px">Token de Acesso</div>
              <div style="font-size:12.5px;color:var(--text-2);margin-bottom:20px;line-height:1.6">Gere o token em <strong>Cardápio Web → Configurações → Integrações → API de Integração</strong> e cole abaixo.</div>
              <div class="form-group" style="margin-bottom:14px">
                <label class="form-label">Token da API</label>
                <input type="password" id="cw-token" placeholder="cw_live_xxxxxxxxxxxxxxxx" style="font-family:monospace;font-size:12px">
              </div>
              <div class="form-group" style="margin-bottom:20px">
                <label class="form-label">ID do Estabelecimento</label>
                <input type="text" id="cw-loja-id" placeholder="Ex: 12345">
              </div>
              <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
                <button class="btn btn-primary" onclick="testarConexao()">Testar Conexão</button>
                <button class="btn btn-ghost" onclick="salvarToken()" id="btn-salvar-token" style="display:none">Salvar e Ativar</button>
                <span class="conn-status disconnected" id="conn-status-badge"><span class="conn-dot"></span> Não conectado</span>
              </div>
              <div id="conn-loading" style="display:none;margin-top:12px">
                <div style="font-size:12px;color:var(--text-3);margin-bottom:4px">Verificando conexão…</div>
                <div class="loading-bar"><div class="loading-fill"></div></div>
              </div>
              <div id="conn-result" style="margin-top:14px;display:none"></div>
            </div>
            <div style="background:var(--surface-2);border-radius:var(--r);padding:20px;border:1px solid var(--border)">
              <div style="font-size:12.5px;font-weight:600;margin-bottom:14px">O que será sincronizado</div>
              <div style="display:flex;flex-direction:column;gap:12px">
                <div style="display:flex;gap:10px"><span style="font-size:16px">📋</span><div><div style="font-size:12.5px;font-weight:500">Catálogo completo</div><div style="font-size:11px;color:var(--text-3);margin-top:2px">Produtos, categorias, preços, complementos, status ativo/inativo</div></div></div>
                <div style="display:flex;gap:10px"><span style="font-size:16px">🛵</span><div><div style="font-size:12.5px;font-weight:500">Pedidos do período</div><div style="font-size:11px;color:var(--text-3);margin-top:2px">Faturamento diário por forma de pagamento → importado direto no Fluxo de Caixa</div></div></div>
                <div style="display:flex;gap:10px"><span style="font-size:16px">📊</span><div><div style="font-size:12.5px;font-weight:500">Volume por produto</div><div style="font-size:11px;color:var(--text-3);margin-top:2px">Quantidade vendida de cada item → calcula CMV real do período</div></div></div>
                <div style="display:flex;gap:10px"><span style="font-size:16px">🏪</span><div><div style="font-size:12.5px;font-weight:500">Dados da loja</div><div style="font-size:11px;color:var(--text-3);margin-top:2px">Formas de pagamento aceitas, horários, configurações de entrega</div></div></div>
                <div style="display:flex;gap:10px"><span style="font-size:16px">🔔</span><div><div style="font-size:12.5px;font-weight:500">Webhook em tempo real</div><div style="font-size:11px;color:var(--text-3);margin-top:2px">Notificação automática a cada novo pedido recebido</div></div></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Catálogo -->
        <div class="integ-panel" id="ip-catalogo" style="padding:0">
          <div style="padding:18px 24px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border);flex-wrap:wrap;gap:10px">
            <div>
              <div style="font-size:13.5px;font-weight:600">Produtos do Cardápio Web</div>
              <div style="font-size:11.5px;color:var(--text-3);margin-top:2px">Última sync: <span id="cat-last-sync">—</span></div>
            </div>
            <div style="display:flex;gap:12px;align-items:center">
              <div style="display:flex;gap:8px;align-items:center;font-size:11.5px;color:var(--text-3)">
                <span style="display:flex;align-items:center;gap:4px"><span style="width:8px;height:8px;border-radius:50%;background:var(--green);display:inline-block"></span>Com ficha</span>
                <span style="display:flex;align-items:center;gap:4px"><span style="width:8px;height:8px;border-radius:50%;background:var(--yellow);display:inline-block"></span>Sem ficha</span>
                <span style="display:flex;align-items:center;gap:4px"><span style="width:8px;height:8px;border-radius:50%;background:var(--text-3);display:inline-block"></span>Inativo</span>
              </div>
              <button class="btn btn-primary btn-sm" onclick="importarCatalogo()">↓ Importar Catálogo</button>
            </div>
          </div>
          <div id="catalogo-loading" style="display:none;padding:20px 24px">
            <div style="font-size:12px;color:var(--text-3);margin-bottom:6px">Buscando produtos no Cardápio Web…</div>
            <div class="loading-bar"><div class="loading-fill"></div></div>
          </div>
          <div id="catalogo-content">
            <div class="empty"><div class="empty-icon">📋</div><div class="empty-title">Catálogo não importado</div><div class="empty-sub">Configure o token na aba Conexão e clique em "Importar Catálogo"</div></div>
          </div>
        </div>

        <!-- Pedidos -->
        <div class="integ-panel" id="ip-pedidos" style="padding:0">
          <div style="padding:18px 24px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--border);flex-wrap:wrap;gap:12px">
            <div>
              <div style="font-size:13.5px;font-weight:600">Importar Pedidos</div>
              <div style="font-size:11.5px;color:var(--text-2);margin-top:2px;max-width:460px">Os pedidos são agrupados por dia e forma de pagamento e inseridos automaticamente no Fluxo de Caixa — sem digitação manual.</div>
            </div>
            <div style="display:flex;gap:10px;align-items:flex-end">
              <div class="form-group" style="margin:0"><label class="form-label" style="margin-bottom:4px">Período</label><input type="month" id="ped-periodo" style="width:155px"></div>
              <button class="btn btn-primary" onclick="importarPedidos()">↓ Importar</button>
            </div>
          </div>
          <div id="pedidos-loading" style="display:none;padding:20px 24px">
            <div style="font-size:12px;color:var(--text-3);margin-bottom:6px">Buscando pedidos do período…</div>
            <div class="loading-bar"><div class="loading-fill"></div></div>
          </div>
          <div id="pedidos-kpis" style="display:none;padding:20px 24px;border-bottom:1px solid var(--border)">
            <div class="import-grid">
              <div class="import-card"><div class="import-card-title">Total de Pedidos</div><div class="import-card-value" id="pk-total">—</div><div class="import-card-sub">no período</div></div>
              <div class="import-card"><div class="import-card-title">Faturamento Bruto</div><div class="import-card-value" id="pk-fat">—</div><div class="import-card-sub">soma dos pedidos</div></div>
              <div class="import-card"><div class="import-card-title">Ticket Médio</div><div class="import-card-value" id="pk-ticket">—</div><div class="import-card-sub">por pedido</div></div>
            </div>
          </div>
          <div id="pedidos-content">
            <div class="empty"><div class="empty-icon">🛵</div><div class="empty-title">Nenhum pedido importado</div><div class="empty-sub">Selecione o período e clique em "Importar"</div></div>
          </div>
        </div>

        <!-- Log -->
        <div class="integ-panel" id="ip-log" style="padding:0">
          <div style="padding:14px 24px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center">
            <div style="font-size:13.5px;font-weight:600">Histórico de Sincronizações</div>
            <button class="btn btn-ghost btn-sm" onclick="limparLog()">Limpar</button>
          </div>
          <div id="sync-log-content">
            <div class="empty"><div class="empty-icon">🗂</div><div class="empty-title">Sem sincronizações ainda</div><div class="empty-sub">As importações realizadas aparecerão aqui</div></div>
          </div>
        </div>
      </div>
    </section>

  </div>
</div>

<div id="toast"></div>

